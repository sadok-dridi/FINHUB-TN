{% extends 'admin/layout.html.twig' %}

{% block title %}KYC Requests - FINHUB{% endblock %}

{% block admin_stylesheets %}
<style>
    /* Support Center Header */
    .support-header-container {
        text-align: center;
        margin-bottom: 2.5rem;
    }
    
    .support-title {
        font-size: 2rem;
        font-weight: 600;
        color: #E5E7EB;
        margin-bottom: 0.5rem;
    }
    
    .support-subtitle {
        font-size: 0.95rem;
        color: #9CA3AF;
        margin-bottom: 2rem;
    }
    
    .support-nav {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }
    
    .support-tab {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #9CA3AF;
        background: transparent;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
    }
    
    .support-tab:hover {
        color: #E5E7EB;
        background: rgba(255, 255, 255, 0.05);
    }
    
    .support-tab.active {
        background: rgba(139, 92, 246, 0.2);
        color: #E5E7EB;
        border: 1px solid rgba(139, 92, 246, 0.3);
    }

    /* Section Header */
    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #E9D5FF;
        margin: 0;
    }

    .btn-refresh {
        background: transparent;
        border: none;
        color: #9CA3AF;
        cursor: pointer;
        padding: 0.5rem;
        border-radius: 50%;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .btn-refresh:hover {
        color: #E5E7EB;
        background: rgba(255, 255, 255, 0.1);
        transform: rotate(180deg);
    }

    /* KYC Grid */
    .kyc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .kyc-card {
        background: rgba(30, 27, 50, 0.6);
        border-radius: 12px;
        padding: 1.25rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        flex-direction: column;
        gap: 1rem;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .kyc-card:hover {
        background: rgba(40, 36, 65, 0.8);
        border-color: rgba(139, 92, 246, 0.4);
        transform: translateY(-2px);
    }

    .card-header {
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }

    .type-badge {
        font-size: 0.65rem;
        font-weight: 700;
        padding: 0.25rem 0.5rem;
        border-radius: 6px;
        background: rgba(139, 92, 246, 0.15);
        color: #8B5CF6;
    }

    .status-badge {
        font-size: 0.65rem;
        font-weight: 700;
        padding: 0.25rem 0.5rem;
        border-radius: 6px;
    }

    .status-PENDING {
        background: rgba(245, 158, 11, 0.15);
        color: #F59E0B;
    }

    .status-APPROVED {
        background: rgba(16, 185, 129, 0.15);
        color: #10B981;
    }

    .status-REJECTED {
        background: rgba(239, 68, 68, 0.15);
        color: #EF4444;
    }

    .card-body {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .user-email {
        font-size: 1rem;
        font-weight: 600;
        color: #E5E7EB;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .submission-date {
        font-size: 0.8rem;
        color: #9CA3AF;
    }

    .empty-state {
        text-align: center;
        padding: 3rem;
        color: #9CA3AF;
        background: rgba(30, 27, 50, 0.4);
        border-radius: 12px;
        border: 1px dashed rgba(255, 255, 255, 0.05);
        grid-column: 1 / -1;
    }

    /* Modal Details Container (hidden initially) */
    .details-container {
        display: none;
        background: rgba(30, 27, 50, 0.6);
        border-radius: 12px;
        padding: 2rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .details-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    
    .btn-back {
        background: rgba(255,255,255,0.05);
        border: none;
        color: #E5E7EB;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s;
    }
    
    .btn-back:hover {
        background: rgba(255,255,255,0.1);
    }

    .details-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
    }
    
    .user-info-side, .request-info-side {
        background: rgba(0,0,0,0.2);
        padding: 1.5rem;
        border-radius: 8px;
    }
    
    .info-group {
        margin-bottom: 1rem;
    }
    .info-label {
        font-size: 0.8rem;
        color: #9CA3AF;
        margin-bottom: 0.25rem;
    }
    .info-value {
        font-size: 1rem;
        color: #E5E7EB;
        font-weight: 500;
    }
    
    .profile-photo {
        width: 100%;
        max-width: 240px;
        aspect-ratio: 1 / 1;
        border-radius: 16px;
        object-fit: cover;
        margin-bottom: 1rem;
        border: 2px solid rgba(139, 92, 246, 0.45);
        background: rgba(255,255,255,0.03);
        display: block;
    }

    .photo-compare-block {
        margin-bottom: 1.5rem;
    }

    .photo-compare-title {
        font-size: 0.82rem;
        color: #9CA3AF;
        margin-bottom: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .photo-empty {
        width: 100%;
        max-width: 240px;
        aspect-ratio: 1 / 1;
        border-radius: 16px;
        border: 1px dashed rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.02);
        color: #6B7280;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 1rem;
    }

    .document-preview {
        width: 100%;
        max-height: 300px;
        object-fit: contain;
        border-radius: 8px;
        margin-top: 1rem;
        background: #000;
    }
    
    .actions-container {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255,255,255,0.1);
    }
    
    .btn-approve, .btn-reject, .btn-video {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        border: none;
        flex: 1;
        transition: all 0.2s;
        text-align: center;
        text-decoration: none;
        color: white;
    }
    
    .btn-approve {
        background: rgba(16, 185, 129, 0.2);
        color: #10B981;
        border: 1px solid rgba(16, 185, 129, 0.5);
    }
    .btn-approve:hover { background: rgba(16, 185, 129, 0.3); }
    
    .btn-reject {
        background: rgba(239, 68, 68, 0.2);
        color: #EF4444;
        border: 1px solid rgba(239, 68, 68, 0.5);
    }
    .btn-reject:hover { background: rgba(239, 68, 68, 0.3); }
    
    .btn-video {
        background: rgba(59, 130, 246, 0.2);
        color: #3B82F6;
        border: 1px solid rgba(59, 130, 246, 0.5);
        display: inline-block;
        margin-top: 1rem;
        width: 100%;
        box-sizing: border-box;
    }
    .btn-video:hover { background: rgba(59, 130, 246, 0.3); }
    @media (max-width: 768px) {
        .support-nav { gap: 0.5rem; }
        .support-tab { font-size: 0.8rem; padding: 0.4rem 0.8rem; }
        .details-content { grid-template-columns: 1fr; gap: 1rem; }
        .details-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
        .actions-container { flex-direction: column; }
        .kyc-grid { grid-template-columns: 1fr; }
        .details-container { padding: 1rem; }
        .user-info-side, .request-info-side { padding: 1rem; }
    }
</style>
{% endblock %}

{% block admin_content %}
<div class="page-container">

    <!-- Header Section -->
    <div class="support-header-container">
        <h1 class="support-title">Support & Safety Center</h1>
        <p class="support-subtitle">Manage user support tickets, system alerts, and compliance requests.</p>
        
        <div class="support-nav">
            <a href="{{ path('app_admin_support') }}" class="support-tab">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                Support Tickets
            </a>
            <a href="{{ path('app_admin_support_alerts') }}" class="support-tab">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                System Alerts
            </a>
            <a href="{{ path('app_admin_support_kyc') }}" class="support-tab active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M9 12l2 2 4-4"></path></svg>
                KYC Requests
            </a>
            <a href="{{ path('app_admin_support_kb') }}" class="support-tab">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                Knowledge Base
            </a>
        </div>
    </div>

    <!-- KYC List -->
    <div id="kycListView">
        <div class="section-header">
            <h2 class="section-title">KYC Requests</h2>
            <button class="btn-refresh" onclick="window.location.reload();" title="Refresh Requests">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
            </button>
        </div>

        <div class="kyc-grid">
            {% if kyc_requests is empty %}
                <div class="empty-state">No KYC requests found.</div>
            {% else %}
                {% for req in kyc_requests %}
                    <a href="#" class="kyc-card" onclick="showKycDetails(this); return false;"
                       data-id="{{ req.request_id }}"
                       data-type="{{ req.document_type }}"
                       data-status="{{ req.status }}"
                       data-email="{{ req.email }}"
                       data-fullname="{{ req.full_name|default('Unknown User') }}"
                       data-role="{{ req.role|default('N/A') }}"
                       data-phone="{{ req.phone_number|default('No Phone') }}"
                       data-trust="{{ req.trust_score|default('0') }}"
                       data-photo="{{ req.profile_photo_url|default('') }}"
                       data-docurl="{{ req.document_url|default('') }}"
                       data-date="{{ req.submission_date|slice(0, 16) }}">
                        <div class="card-header">
                            <span class="type-badge">{{ req.document_type|default('UNKNOWN') }}</span>
                            <span class="status-badge status-{{ req.status|default('PENDING') }}">{{ req.status|default('PENDING') }}</span>
                        </div>
                        <div class="card-body">
                            <div class="user-email" title="{{ req.email }}">{{ req.email }}</div>
                            <div class="submission-date">Submitted: {{ req.submission_date|slice(0, 16) }}</div>
                        </div>
                    </a>
                {% endfor %}
            {% endif %}
        </div>
    </div>

    <!-- KYC Details View -->
    <div id="kycDetailsView" class="details-container">
        <div class="details-header">
            <button class="btn-back" onclick="hideKycDetails();">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                Back to Requests
            </button>
            <h2 class="section-title">Review KYC Request</h2>
        </div>

        <div class="details-content">
            <!-- User Info Side -->
            <div class="user-info-side">
                <div class="photo-compare-block">
                    <div class="photo-compare-title">Profile Photo</div>
                    <img id="detailProfilePhoto" src="" alt="Profile" class="profile-photo" style="display: none;">
                    <div id="detailProfilePhotoFallback" class="photo-empty" style="display: none;">No profile photo uploaded</div>
                </div>
                <div class="info-group">
                    <div class="info-label">Full Name</div>
                    <div class="info-value" id="detailFullName"></div>
                </div>
                <div class="info-group">
                    <div class="info-label">Email</div>
                    <div class="info-value" id="detailEmail"></div>
                </div>
                <div class="info-group">
                    <div class="info-label">Role</div>
                    <div class="info-value" id="detailRole"></div>
                </div>
                <div class="info-group">
                    <div class="info-label">Phone Number</div>
                    <div class="info-value" id="detailPhone"></div>
                </div>
                <div class="info-group">
                    <div class="info-label">Trust Score</div>
                    <div class="info-value" id="detailTrust"></div>
                </div>
            </div>

            <!-- Request Info Side -->
            <div class="request-info-side">
                <div class="info-group">
                    <div class="info-label">Document Type</div>
                    <div class="info-value"><span id="detailTypeBadge" class="type-badge" style="font-size: 0.8rem;"></span></div>
                </div>
                <div class="info-group">
                    <div class="info-label">Submission Date</div>
                    <div class="info-value" id="detailDate"></div>
                </div>
                
                <div class="info-group" style="margin-top: 1.5rem;">
                    <div class="info-label">Provided Document</div>
                    <img id="detailDocumentImage" class="document-preview" src="" alt="Document" style="display: none;">
                    <a id="detailVideoButton" href="#" target="_blank" class="btn-video" style="display: none;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 5px;"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
                        Open Video
                    </a>
                </div>

                <div id="actionsContainer" class="actions-container" style="display: none;">
                    <button class="btn-approve" onclick="updateKycStatus('APPROVED')">Approve Request</button>
                    <button class="btn-reject" onclick="updateKycStatus('REJECTED')">Reject Request</button>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
    let currentRequestId = null;

    function showKycDetails(element) {
        currentRequestId = element.dataset.id;
        
        // Populate User Info
        document.getElementById('detailFullName').textContent = element.dataset.fullname;
        document.getElementById('detailEmail').textContent = element.dataset.email;
        document.getElementById('detailRole').textContent = element.dataset.role;
        document.getElementById('detailPhone').textContent = element.dataset.phone;
        document.getElementById('detailTrust').textContent = element.dataset.trust;
        
        const photoUrl = element.dataset.photo;
        const photoImg = document.getElementById('detailProfilePhoto');
        const photoFallback = document.getElementById('detailProfilePhotoFallback');
        if (photoUrl) {
            photoImg.src = photoUrl;
            photoImg.style.display = 'block';
            photoFallback.style.display = 'none';
        } else {
            photoImg.style.display = 'none';
            photoFallback.style.display = 'flex';
        }

        // Populate Request Info
        document.getElementById('detailTypeBadge').textContent = element.dataset.type;
        document.getElementById('detailDate').textContent = element.dataset.date;
        
        const docType = element.dataset.type;
        const docUrl = element.dataset.docurl;
        const docImg = document.getElementById('detailDocumentImage');
        const videoBtn = document.getElementById('detailVideoButton');

        if (docType === 'ID_CARD') {
            docImg.src = docUrl;
            docImg.style.display = 'block';
            videoBtn.style.display = 'none';
        } else {
            docImg.style.display = 'none';
            videoBtn.href = docUrl;
            videoBtn.style.display = 'inline-block';
        }

        // Handle Actions visibility
        const status = element.dataset.status;
        const actionsContainer = document.getElementById('actionsContainer');
        if (status === 'PENDING') {
            actionsContainer.style.display = 'flex';
        } else {
            actionsContainer.style.display = 'none';
        }

        // Toggle Views
        document.getElementById('kycListView').style.display = 'none';
        document.getElementById('kycDetailsView').style.display = 'block';
    }

    function hideKycDetails() {
        currentRequestId = null;
        document.getElementById('kycDetailsView').style.display = 'none';
        document.getElementById('kycListView').style.display = 'block';
    }

    function updateKycStatus(status) {
        if (!currentRequestId) return;
        
        if (!confirm('Are you sure you want to ' + status.toLowerCase() + ' this request?')) {
            return;
        }

        fetch('/admin/support/kyc/' + currentRequestId + '/status', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({ status: status })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert('Status updated successfully!');
                window.location.reload();
            } else {
                alert('Error: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('An error occurred while updating the status.');
        });
    }
</script>
{% endblock %}
