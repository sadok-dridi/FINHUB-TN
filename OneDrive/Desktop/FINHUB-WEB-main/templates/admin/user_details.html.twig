{% extends 'admin/layout.html.twig' %}

{% block title %}User Details - FINHUB{% endblock %}

{% block admin_stylesheets %}
<style>
    .details-grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }
    
    .action-buttons {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.5rem;
        align-items: center;
        flex-wrap: wrap;
    }
    
    .danger-zone-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }

    @media (max-width: 991px) {
        .details-grid {
            grid-template-columns: 1fr;
        }
        .action-buttons {
            flex-direction: column;
            align-items: stretch;
        }
        .action-buttons > div {
            display: none; /* Hide flex-grow spacer */
        }
        .btn-portfolio, .btn-freeze {
            width: 100%;
        }
        .danger-zone-content {
            flex-direction: column;
            align-items: stretch;
        }
        .danger-zone-content .btn-delete {
            width: 100%;
            margin-top: 1rem;
        }
        .info-row {
            flex-direction: column;
            gap: 0.2rem;
        }
    }
</style>
{% endblock %}

{% block admin_content %}
<div class="page-container">
    <div class="details-header" style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
        <button onclick="window.location.href='{{ path('app_admin_users') }}'" class="btn-back" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; padding: 0.5rem 1rem; border-radius: 6px; cursor: pointer; transition: all 0.2s;">
            Back
        </button>
        <h1 class="page-title" style="margin: 0; font-size: clamp(1.4rem, 4vw, 1.8rem); font-weight: 600; text-shadow: 0 0 10px rgba(139, 92, 246, 0.5);">User Details</h1>
    </div>

    <div class="details-grid">
        
        {# Personal Information Card #}
        <div class="glass-card" style="background: rgba(30, 27, 50, 0.8); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 1.5rem; word-break: break-word;">
            <h2 style="font-size: 1.1rem; margin-top: 0; margin-bottom: 1.5rem; color: #E5E7EB; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 0.5rem;">Personal Information</h2>
            
            <div class="info-row" style="display: flex; margin-bottom: 1rem;">
                <div style="width: 100px; color: #9CA3AF; font-size: 0.9rem;">Full Name</div>
                <div style="color: #E5E7EB; font-size: 0.95rem; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="{{ targetUser.fullName|default('N/A') }}">{{ targetUser.fullName|default('N/A') }}</div>
            </div>
            <div class="info-row" style="display: flex; margin-bottom: 1rem;">
                <div style="width: 100px; color: #9CA3AF; font-size: 0.9rem;">Email</div>
                <div style="color: #E5E7EB; font-size: 0.95rem; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="{{ targetUser.email }}">{{ targetUser.email }}</div>
            </div>
            <div class="info-row" style="display: flex; margin-bottom: 1rem;">
                <div style="width: 100px; color: #9CA3AF; font-size: 0.9rem;">Role</div>
                <div style="color: #E5E7EB; font-size: 0.95rem; font-weight: 500;">{{ targetUser.role|default('USER') }}</div>
            </div>
            <div class="info-row" style="display: flex; margin-bottom: 0;">
                <div style="width: 100px; color: #9CA3AF; font-size: 0.9rem;">ID</div>
                <div style="color: #9CA3AF; font-size: 0.95rem;">User ID: {{ targetUser.id }}</div>
            </div>
        </div>

        {# Wallet Status Card #}
        <div class="glass-card" style="background: rgba(30, 27, 50, 0.8); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 1.5rem; width: 100%; overflow: hidden;">
            <h2 style="font-size: 1.1rem; margin-top: 0; margin-bottom: 1.5rem; color: #E5E7EB; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 0.5rem;">Wallet Status</h2>
            
            <div style="display: flex; align-items: baseline; gap: 0.5rem; margin-bottom: 1rem;">
                <span id="walletBalance" style="font-size: clamp(1.5rem, 5vw, 2.2rem); font-weight: 600; color: #8B5CF6; word-break: break-all;">
                    {{ targetUser.wallet ? targetUser.wallet.balance|number_format(2, '.', '') : 'N/A' }}
                </span>
                <span style="color: #9CA3AF; font-size: 1.1rem;">{{ targetUser.wallet ? targetUser.wallet.currency : 'TND' }}</span>
            </div>
            
            <div style="margin-bottom: 1.5rem;">
                <span style="color: #9CA3AF; margin-right: 0.5rem;">Status</span>
                {% if targetUser.wallet %}
                    <span id="walletStatusBadge" style="font-weight: 600; color: {{ targetUser.wallet.status == 'FROZEN' ? '#EF4444' : '#10B981' }};">
                        {{ targetUser.wallet.status }}
                    </span>
                {% else %}
                    <span style="color: #9CA3AF;">No Wallet</span>
                {% endif %}
            </div>

            <div style="height: 120px; width: 100%; position: relative;">
                <canvas id="balanceChart"></canvas>
            </div>
        </div>
    </div>

    {# Action Buttons #}
    <div class="action-buttons">
        <button onclick="window.location.href='{{ path('app_admin_user_portfolio', {'id': targetUser.id}) }}'" class="btn-portfolio" style="background: #8B5CF6; border: none; color: white; padding: 0.6rem 1.5rem; border-radius: 8px; font-weight: 500; cursor: pointer; transition: all 0.2s; box-shadow: 0 0 15px rgba(139, 92, 246, 0.4);">
            View Portfolio
        </button>
        
        <button id="freezeBtn" class="btn-freeze" style="background: {{ targetUser.wallet and targetUser.wallet.status == 'FROZEN' ? '#10B981' : '#F59E0B' }}; border: none; color: white; padding: 0.6rem 1.5rem; border-radius: 8px; font-weight: 500; cursor: pointer; transition: all 0.2s;">
            {{ targetUser.wallet and targetUser.wallet.status == 'FROZEN' ? 'Unfreeze Wallet' : 'Freeze Wallet' }}
        </button>
        
        <div style="flex-grow: 1;"></div>
    </div>

    {# Danger Zone #}
    <div class="danger-zone" style="background: rgba(220, 38, 38, 0.05); border: 1px solid rgba(220, 38, 38, 0.3); border-radius: 12px; padding: 1.5rem; display: flex; flex-direction: column; gap: 1.5rem;">
        <div style="color: #EF4444; font-weight: 500;">Danger Zone</div>
        
        <div class="danger-zone-content">
            <div style="color: #9CA3AF; font-size: 0.95rem; line-height: 1.4;">
                Once you delete a user, there is no going back. Please be certain.
            </div>
            
            <button onclick="confirmDelete()" class="btn-delete" style="background: #EF4444; border: none; color: white; padding: 0.6rem 1.5rem; border-radius: 8px; font-weight: 500; cursor: pointer; transition: all 0.2s; box-shadow: 0 0 15px rgba(239, 68, 68, 0.3);">
                Delete User
            </button>
        </div>
    </div>
</div>

{# Delete User Modal #}
<div id="deleteModal" class="modal-overlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(5px); z-index: 50; align-items: center; justify-content: center;">
    <div class="modal-content" style="background: rgba(25, 23, 40, 0.95); border: 1px solid rgba(239, 68, 68, 0.4); border-radius: 12px; padding: 2rem; width: 100%; max-width: 400px; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
        <h2 style="color: #EF4444; margin-top: 0; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
            Delete User
        </h2>
        
        <p style="color: #E5E7EB; font-size: 0.95rem; margin-bottom: 1rem; line-height: 1.5;">
            Are you sure you want to delete <strong>{{ targetUser.fullName|default(targetUser.email) }}</strong>?<br><br>
            This will:<br>
            - LIQUIDATE all portfolio assets.<br>
            - TRANSFER total balance to Central Bank.<br>
            - PERMANENTLY DELETE all user data.<br>
            - THIS CANNOT BE UNDONE.
        </p>

        <p style="color: #9CA3AF; font-size: 0.9rem; margin-bottom: 0.5rem;">
            Please enter your Admin Password to confirm:
        </p>

        <input type="password" id="adminPassword" placeholder="Admin Password" style="width: 100%; padding: 0.75rem; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; color: white; margin-bottom: 1.5rem; outline: none; transition: border-color 0.2s;">

        <div style="display: flex; gap: 1rem; justify-content: flex-end;">
            <button onclick="closeDeleteModal()" style="background: transparent; border: 1px solid rgba(255,255,255,0.2); color: white; padding: 0.5rem 1rem; border-radius: 6px; cursor: pointer;">
                Cancel
            </button>
            <button onclick="submitDelete()" id="submitDeleteBtn" style="background: #EF4444; border: none; color: white; padding: 0.5rem 1rem; border-radius: 6px; cursor: pointer; font-weight: 500;">
                Confirm Delete
            </button>
        </div>
    </div>
</div>
{% endblock %}

{% block admin_javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Sparkline Chart
        document.addEventListener('DOMContentLoaded', function() {
            const ctx = document.getElementById('balanceChart').getContext('2d');
            const data = {{ sparklineData|raw }};
            const labels = {{ sparklineLabels|raw }};
            
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        borderColor: '#8B5CF6',
                        borderWidth: 2,
                        tension: 0.1,
                        pointRadius: 0,
                        pointHoverRadius: 4,
                        pointBackgroundColor: '#8B5CF6',
                        fill: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.parsed.y.toFixed(2) + ' TND';
                                },
                                title: function() { return ''; }
                            },
                            displayColors: false,
                            backgroundColor: 'rgba(30, 27, 50, 0.9)',
                            titleColor: '#fff',
                            bodyColor: '#fff',
                            borderColor: 'rgba(255,255,255,0.1)',
                            borderWidth: 1
                        }
                    },
                    scales: {
                        x: { display: true, grid: { display: false, drawBorder: false }, ticks: { color: '#9CA3AF', maxTicksLimit: 5 } },
                        y: { display: true, grid: { display: false, drawBorder: false }, ticks: { color: '#9CA3AF', maxTicksLimit: 4 } }
                    },
                    layout: { padding: 0 }
                }
            });
        });

        document.addEventListener('DOMContentLoaded', function() {
            const btn = document.getElementById('freezeBtn');
            if (btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    console.log("Freeze button clicked via event listener");
                    
                    const hasWallet = {{ targetUser.wallet ? 'true' : 'false' }};
                    if (!hasWallet) {
                        alert('User has no wallet to freeze.');
                        return;
                    }

                    const statusBadge = document.getElementById('walletStatusBadge');
                    if (!statusBadge) {
                        alert('Error: Status badge not found in DOM.');
                        return;
                    }

                    const isFrozen = statusBadge.innerText.trim() === 'FROZEN';
                    const actionText = isFrozen ? 'unfreeze' : 'freeze';
                    const userName = "{{ targetUser.email }}";

                    if (!confirm('Are you sure you want to ' + actionText + ' the wallet for ' + userName + '?')) {
                        return;
                    }

                    const originalText = btn.innerText;
                    btn.innerText = 'Processing...';
                    btn.disabled = true;

                    fetch('{{ path('app_admin_user_freeze', {'id': targetUser.id}) }}', {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'Content-Type': 'application/json'
                        }
                    })
                    .then(res => {
                        if (!res.ok && res.status !== 400 && res.status !== 404) {
                            throw new Error('Server returned ' + res.status);
                        }
                        return res.json();
                    })
                    .then(data => {
                        if (data.success) {
                            if (data.newStatus === 'FROZEN') {
                                statusBadge.innerText = 'FROZEN';
                                statusBadge.style.color = '#EF4444';
                                btn.innerText = 'Unfreeze Wallet';
                                btn.style.background = '#10B981';
                            } else {
                                statusBadge.innerText = 'ACTIVE';
                                statusBadge.style.color = '#10B981';
                                btn.innerText = 'Freeze Wallet';
                                btn.style.background = '#F59E0B';
                            }
                            alert('Success:\n\n' + data.message);
                        } else {
                            btn.innerText = originalText;
                            alert('Error:\n\n' + data.message);
                        }
                        btn.disabled = false;
                    })
                    .catch(err => {
                        btn.innerText = originalText;
                        btn.disabled = false;
                        alert('Error:\n\n' + err.message);
                    });
                });
            }
        });

        // Delete Modal Logic
        const modal = document.getElementById('deleteModal');
        const pwdInput = document.getElementById('adminPassword');
        
        function confirmDelete() {
            modal.style.display = 'flex';
            pwdInput.value = '';
            setTimeout(() => pwdInput.focus(), 100);
        }
        
        function closeDeleteModal() {
            modal.style.display = 'none';
        }
        
        function submitDelete() {
            const password = pwdInput.value;
            if (!password) {
                alert('Error:\n\nPlease enter your admin password.');
                return;
            }

            const btn = document.getElementById('submitDeleteBtn');
            const originalText = btn.innerText;
            btn.innerText = 'Processing...';
            btn.disabled = true;

            fetch('{{ path('app_admin_user_delete', {'id': targetUser.id}) }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ password: password })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert('Success:\n\n' + data.message);
                    window.location.href = '{{ path('app_admin_users') }}';
                } else {
                    alert('Error:\n\n' + data.message);
                    btn.innerText = originalText;
                    btn.disabled = false;
                }
            })
            .catch(err => {
                alert('Error:\n\nNetwork error occurred.');
                btn.innerText = originalText;
                btn.disabled = false;
            });
        }
    </script>
{% endblock %}