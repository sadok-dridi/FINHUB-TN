{% extends 'base.html.twig' %}

{% block title %}FinHub - Admin Area{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* Hide the public floating navbar for the user area */
        .navbar-floating-wrapper { display: none !important; }

        * { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }

        body {
            background-color: transparent !important;
            margin: 0; padding: 0;
            overflow: hidden;
        }

        /* ══════════ LAYOUT ══════════ */
        .admin-layout {
            display: flex;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
        }

        /* ══════════ SIDEBAR ══════════ */
        .admin-sidebar {
            width: 260px;
            min-width: 260px;
            height: 100vh;
            position: fixed;
            top: 0; left: 0;
            background: rgba(12, 11, 22, 0.85);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-right: 1px solid rgba(255, 255, 255, 0.06);
            display: flex;
            flex-direction: column;
            z-index: 1000;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            overflow-y: auto;
            overflow-x: hidden;
        }
        .admin-sidebar::-webkit-scrollbar { width: 0; }

        .sidebar-header {
            padding: 20px 22px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .sidebar-brand {
            font-size: 1.15rem;
            font-weight: 700;
            color: #fff;
            letter-spacing: 2px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .sidebar-brand .dot {
            width: 8px; height: 8px;
            background: #34D399;
            border-radius: 50%;
            box-shadow: 0 0 10px rgba(52, 211, 153, 0.6);
        }
        .sidebar-brand .tn { color: #8B5CF6; }

        /* Profile variants: header-inline for mobile, full block for desktop */
        .sidebar-profile-header { display: none !important; }
        .sidebar-profile-full { display: flex; }
        .mobile-logout { display: none !important; }

        /* ── Profile Section ── */
        .sidebar-profile {
            padding: 20px 22px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.06);
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .sidebar-avatar {
            width: 42px; height: 42px;
            border-radius: 50%;
            flex-shrink: 0;
            position: relative;
            overflow: hidden;
            background: linear-gradient(135deg, rgba(139,92,246,0.3), rgba(217,70,239,0.3));
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid rgba(139, 92, 246, 0.4);
        }
        .sidebar-avatar img {
            width: 100%; height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }
        .sidebar-avatar .avatar-letter {
            font-weight: 700;
            font-size: 1rem;
            color: #E9D5FF;
            text-transform: uppercase;
        }

        .profile-info { min-width: 0; }
        .profile-name {
            color: #F3F4F6;
            font-size: 0.9rem;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .profile-role {
            font-size: 0.68rem;
            font-weight: 600;
            letter-spacing: 1.5px;
            color: #8B5CF6;
            text-transform: uppercase;
        }

        /* ── Navigation ── */
        .nav-section-title {
            color: #6B7280;
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 1.5px;
            padding: 22px 22px 8px;
            text-transform: uppercase;
        }
        .admin-nav {
            list-style: none;
            padding: 0; margin: 0;
            flex-grow: 1;
        }
        .nav-item-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 16px;
            margin: 2px 10px;
            color: #9CA3AF;
            text-decoration: none;
            font-size: 0.88rem;
            font-weight: 500;
            border-radius: 10px;
            transition: all 0.2s ease;
            position: relative;
        }
        .nav-item-link:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #E5E7EB;
        }
        .nav-item-link.active {
            background: linear-gradient(135deg, rgba(139,92,246,0.2), rgba(139,92,246,0.1));
            color: #fff;
            font-weight: 600;
            box-shadow: 0 0 20px rgba(139, 92, 246, 0.1);
        }
        .nav-item-link.active::before {
            content: '';
            position: absolute;
            left: 0; top: 50%;
            transform: translateY(-50%);
            width: 3px; height: 60%;
            background: #8B5CF6;
            border-radius: 0 3px 3px 0;
        }
        .nav-icon {
            width: 20px; height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .nav-icon svg { width: 18px; height: 18px; }
        .nav-item-link.active .nav-icon svg { stroke: #A78BFA; }
        .nav-label { white-space: nowrap; }

        /* ── Logout ── */
        .sidebar-footer {
            padding: 16px 22px;
            margin-top: auto;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
        }
        .logout-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            width: 100%;
            color: #EF4444;
            background: rgba(239, 68, 68, 0.08);
            border: 1px solid rgba(239, 68, 68, 0.15);
            padding: 10px 16px;
            border-radius: 10px;
            text-decoration: none;
            font-size: 0.88rem;
            font-weight: 500;
            transition: all 0.2s ease;
        }
        .logout-btn:hover {
            background: rgba(239, 68, 68, 0.15);
            color: #F87171;
        }

        /* ══════════ MAIN CONTENT ══════════ */
        .admin-content {
            flex: 1;
            margin-left: 260px;
            height: 100vh;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 32px 40px;
            scroll-behavior: smooth;
        }
        .admin-content::-webkit-scrollbar { width: 6px; }
        .admin-content::-webkit-scrollbar-track { background: transparent; }
        .admin-content::-webkit-scrollbar-thumb {
            background: rgba(139, 92, 246, 0.25);
            border-radius: 10px;
        }

        /* ══════════ WALLET CONTENT STYLES ══════════ */
        .wallet-container { color: white; }

        .header-title {
            font-size: 2rem; font-weight: 600;
            color: #F3F4F6;
            letter-spacing: -0.5px;
        }

        .btn-action-primary {
            background: linear-gradient(135deg, #8B5CF6, #7C3AED);
            color: white;
            border-radius: 12px;
            padding: 10px 22px;
            font-weight: 600;
            border: none;
            transition: all 0.25s ease;
            box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);
            font-size: 0.9rem;
        }
        .btn-action-primary:hover {
            background: linear-gradient(135deg, #7C3AED, #6D28D9);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(139, 92, 246, 0.4);
        }

        .btn-action-secondary {
            background: rgba(139, 92, 246, 0.08);
            color: #D8B4FE;
            border-radius: 12px;
            padding: 10px 22px;
            font-weight: 600;
            border: 1px solid rgba(139, 92, 246, 0.2);
            transition: all 0.25s ease;
            font-size: 0.9rem;
        }
        .btn-action-secondary:hover {
            background: rgba(139, 92, 246, 0.15);
            color: white;
            transform: translateY(-2px);
        }

        .dash-card {
            background: rgba(20, 18, 35, 0.6);
            backdrop-filter: blur(16px);
            border-radius: 16px;
            padding: 24px;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            transition: all 0.3s ease;
        }
        .dash-card:hover { transform: translateY(-3px); }

        .card-green-border { border: 1px solid rgba(16, 185, 129, 0.3); }
        .card-orange-border { border: 1px solid rgba(245, 158, 11, 0.3); }
        .card-blue-border { border: 1px solid rgba(59, 130, 246, 0.3); }

        .card-label { font-size: 0.9rem; color: #9CA3AF; margin-bottom: 8px; }
        .card-value { font-size: 2rem; font-weight: 700; color: white; }

        .virtual-card-bg {
            background: linear-gradient(135deg, #32b5e3 0%, #8736e0 50%, #b732d9 100%);
            border-radius: 16px;
            height: 100%; min-height: 220px;
            position: relative; overflow: hidden;
            border: 1px solid rgba(255,255,255,0.1);
            box-shadow: 0 10px 30px rgba(183, 50, 217, 0.2);
            transition: transform 0.3s ease; cursor: pointer;
            padding: 24px;
            display: flex; flex-direction: column; justify-content: space-between;
        }
        .virtual-card-bg:hover { transform: translateY(-4px); }
        .virtual-card-overlay {
            position: absolute; top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(10px);
            display: flex; align-items: center; justify-content: center;
            z-index: 10;
            transition: opacity 0.3s ease, visibility 0.3s ease;
            color: white; font-weight: 600; font-size: 1.1rem; letter-spacing: 1px;
        }
        .virtual-card-bg.revealed .virtual-card-overlay { opacity: 0; visibility: hidden; }
        .virtual-card-top { display: flex; justify-content: space-between; align-items: center; }
        .virtual-card-logo { font-weight: 700; font-size: 1.1rem; color: white; display: flex; align-items: center; gap: 8px; }
        .virtual-card-waves { color: white; font-size: 1.5rem; font-weight: bold; letter-spacing: 2px; }
        .virtual-card-middle { margin-top: 20px; }
        .virtual-card-label { color: rgba(255,255,255,0.7); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; display: block; }
        .virtual-card-number { color: white; font-size: 1.25rem; font-family: 'Courier New', monospace; letter-spacing: 2px; }
        .virtual-card-bottom { display: flex; justify-content: space-between; align-items: flex-end; margin-top: auto; }
        .virtual-card-info { display: flex; flex-direction: column; gap: 4px; }
        .virtual-card-details { color: white; font-size: 0.82rem; display: flex; gap: 16px; }
        .virtual-card-name { color: white; font-size: 0.95rem; font-weight: 500; letter-spacing: 1px; margin-top: 4px; }
        .virtual-card-brand { font-size: 1.8rem; font-weight: 700; font-style: italic; color: white; }

        .section-title { font-size: 1.05rem; color: #E9D5FF; font-weight: 600; margin-bottom: 1rem; margin-top: 1.5rem; letter-spacing: 0.3px; }

        .live-indicator {
            font-size: 0.68rem; font-weight: 600; color: #10B981;
            background: rgba(16, 185, 129, 0.12);
            padding: 4px 10px; border-radius: 20px;
            display: inline-flex; align-items: center; gap: 6px;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }
        .live-dot { width: 6px; height: 6px; background: #10B981; border-radius: 50%; animation: blink 1.5s infinite; }
        @keyframes blink { 0%{opacity:1}50%{opacity:.3}100%{opacity:1} }

        .tx-list { display: flex; flex-direction: column; gap: 10px; }
        .tx-item {
            background: rgba(20, 18, 35, 0.5);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.04);
            border-radius: 14px;
            padding: 14px 18px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.2s ease;
        }
        .tx-item:hover { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.08); }
        .tx-icon-wrapper {
            width: 40px; height: 40px; border-radius: 50%;
            background: linear-gradient(135deg, rgba(16,185,129,0.15), rgba(4,120,87,0.15));
            display: flex; align-items: center; justify-content: center;
            border: 1px solid rgba(16,185,129,0.3);
            overflow: hidden; flex-shrink: 0;
        }
        .tx-icon-wrapper img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
        .tx-details h6 { margin: 0 0 3px 0; color: #E9D5FF; font-size: 0.92rem; font-weight: 500; }
        .tx-details small { color: #6B7280; font-size: 0.78rem; }
        .tx-amount { text-align: right; font-size: 1rem; }
        .tx-amount.negative { color: #FBBF24; }
        .tx-amount.positive { color: #10B981; }

        /* ══════════ RESPONSIVE — MOBILE TOP BAR ══════════ */
        @media (max-width: 991px) {
            body { overflow: auto; }

            .admin-layout {
                flex-direction: column;
                height: auto;
                overflow: visible;
            }

            /* Sidebar becomes a fixed top bar */
            .admin-sidebar {
                position: fixed;
                top: 0; left: 0; right: 0;
                width: 100%;
                min-width: unset;
                height: auto;
                flex-direction: column;
                border-right: none;
                border-bottom: 1px solid rgba(255, 255, 255, 0.06);
                overflow: visible;
                z-index: 1000;
            }

            /* Top row: brand + profile + logout */
            .sidebar-header {
                display: flex;
                align-items: center;
                padding: 12px 16px;
                border-bottom: 1px solid rgba(255, 255, 255, 0.04);
            }

            .sidebar-profile {
                padding: 0;
                border-bottom: none;
                margin-left: auto;
                gap: 8px;
            }
            .sidebar-avatar { width: 30px; height: 30px; }
            .sidebar-avatar .avatar-letter { font-size: 0.75rem; }

            .profile-info { display: none; }

            /* Show inline avatar in header, hide full profile block */
            .sidebar-profile-header { display: flex !important; }
            .sidebar-profile-full { display: none !important; }

            /* Mobile logout in header row */
            .mobile-logout {
                display: flex !important;
                padding: 6px 10px;
                font-size: 0.78rem;
                background: transparent;
                border: 1px solid rgba(239, 68, 68, 0.2);
                margin-left: 8px;
                flex-shrink: 0;
                width: auto;
            }

            /* Hide the section title and bottom footer on mobile */
            .nav-section-title { display: none; }
            .sidebar-footer { display: none; }

            /* Nav becomes horizontal scrollable row */
            .admin-nav {
                display: flex;
                flex-direction: row;
                overflow-x: auto;
                overflow-y: hidden;
                padding: 8px 12px;
                gap: 4px;
                -webkit-overflow-scrolling: touch;
                scrollbar-width: none;
                -ms-overflow-style: none;
                border-top: 1px solid rgba(255, 255, 255, 0.04);
            }
            .admin-nav::-webkit-scrollbar { display: none; }

            .nav-item-link {
                flex-direction: column;
                gap: 4px;
                padding: 8px 14px;
                margin: 0;
                border-radius: 10px;
                font-size: 0.7rem;
                min-width: fit-content;
                text-align: center;
            }
            .nav-item-link.active::before {
                display: none;
            }
            .nav-item-link.active::after {
                content: '';
                position: absolute;
                bottom: 0; left: 50%;
                transform: translateX(-50%);
                width: 60%;
                height: 2px;
                background: #8B5CF6;
                border-radius: 2px 2px 0 0;
            }
            .nav-icon { width: 18px; height: 18px; }
            .nav-icon svg { width: 16px; height: 16px; }

            /* Main content below the top bar */
            .admin-content {
                margin-left: 0;
                margin-top: 0;
                height: auto;
                overflow: visible;
                padding: 20px 16px 32px;
            }
        }

        @media (max-width: 768px) {
            .card-value { font-size: 1.5rem; }
            .header-title { font-size: 1.6rem; }
            .virtual-card-bg { min-height: 180px; }
            .tx-details h6 { font-size: 0.88rem; }
            .btn-action-primary, .btn-action-secondary { padding: 10px 16px; font-size: 0.85rem; }
            .dash-card { padding: 18px; }
        }
    </style>
    {% block admin_stylesheets %}{% endblock %}
{% endblock %}

{% block body %}
<div class="admin-layout" id="adminLayout">

    <!-- ═══ SIDEBAR ═══ -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-header">
            <div class="sidebar-brand">
                <span class="dot"></span>
                FINHUB <span class="tn">TN</span>
            </div>
            <!-- Profile (inline on mobile, hidden below on desktop) -->
            <div class="sidebar-profile sidebar-profile-header">
                <div class="sidebar-avatar" id="sidebarAvatar">
                    {% if app.user.profilePhotoUrl %}
                        <img src="{{ app.user.profilePhotoUrl }}" alt="Profile" id="avatarImg" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                        <span class="avatar-letter" style="display:none;">{{ app.user.fullName|default(app.user.email|default('U'))|slice(0, 1)|upper }}</span>
                    {% else %}
                        <span class="avatar-letter">{{ app.user.fullName|default(app.user.email|default('U'))|slice(0, 1)|upper }}</span>
                    {% endif %}

                </div>
            </div>
            <!-- Logout (visible in header row on mobile only) -->
            <a href="{{ path('app_logout') }}" class="logout-btn mobile-logout" data-turbo="false">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </a>
        </div>

        <!-- Profile Section (desktop only, full version) -->
        <div class="sidebar-profile sidebar-profile-full">
            <div class="sidebar-avatar">
                {% if app.user.profilePhotoUrl %}
                    <img src="{{ app.user.profilePhotoUrl }}" alt="Profile" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                    <span class="avatar-letter" style="display:none;">{{ app.user.fullName|default(app.user.email|default('U'))|slice(0, 1)|upper }}</span>
                {% else %}
                    <span class="avatar-letter">{{ app.user.fullName|default(app.user.email|default('U'))|slice(0, 1)|upper }}</span>
                {% endif %}

            </div>
            <div class="profile-info">
                <div class="profile-name">{{ app.user.fullName|default(app.user.email|split('@')[0]) }}</div>
                <div class="profile-role">ADMIN</div>
            </div>
        </div>

        <div class="nav-section-title">MENU</div>

        <ul class="admin-nav">
            <li><a href="{{ path('app_admin_dashboard') }}" class="nav-item-link {% if app.request.get('_route') == 'app_admin_dashboard' %}active{% endif %}" id="nav-dashboard">
                <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg></span>
                <span class="nav-label">Dashboard</span>
            </a></li>
            <li><a href="{{ path('app_admin_users') }}" class="nav-item-link {% if app.request.get('_route') == 'app_admin_users' %}active{% endif %}" id="nav-users">
                <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
                <span class="nav-label">Users</span>
            </a></li>
            <li><a href="{{ path('app_admin_transactions') }}" class="nav-item-link {% if app.request.get('_route') == 'app_admin_transactions' %}active{% endif %}" id="nav-transactions">
                <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></span>
                <span class="nav-label">Transactions</span>
            </a></li>
            <li><a href="{{ path('app_admin_escrow') }}" class="nav-item-link {% if app.request.get('_route') == 'app_admin_escrow' %}active{% endif %}" id="nav-escrow">
                <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
                <span class="nav-label">Escrows</span>
            </a></li>

            <li><a href="{{ path('app_admin_wallets') }}" class="nav-item-link {% if app.request.get('_route') starts with 'app_admin_wallet' or app.request.get('_route') == 'app_admin_wallets' %}active{% endif %}" id="nav-wallets">
                <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg></span>
                <span class="nav-label">Wallets</span>

            </a></li>
            <li><a href="{{ path('app_admin_support') }}" class="nav-item-link {% if app.request.get('_route') == 'app_admin_support' %}active{% endif %}" id="nav-support">
                <span class="nav-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span>
                <span class="nav-label">Support & Safety</span>
            </a></li>
        </ul>

        <div class="sidebar-footer">
            <a href="{{ path('app_logout') }}" class="logout-btn" data-turbo="false">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                <span class="nav-label">Log Out</span>
            </a>
        </div>
    </aside>

    <!-- ═══ MAIN CONTENT ═══ -->
    <main class="admin-content" id="adminContent">
        {% block admin_content %}{% endblock %}
    </main>

</div>

<!-- Flash Messages -->
<div class="position-fixed top-0 end-0 p-3" style="z-index: 9999">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert" style="box-shadow: 0 5px 15px rgba(0,0,0,0.3); border-radius: 10px;">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}
</div>

<script>
    // Dynamic top margin for mobile: push content below the fixed top-bar
    function adjustMobileMargin() {
        const sidebar = document.getElementById('adminSidebar');
        const content = document.getElementById('adminContent');
        if (window.innerWidth <= 991) {
            content.style.marginTop = sidebar.offsetHeight + 'px';
        } else {
            content.style.marginTop = '0';
        }
    }
    window.addEventListener('resize', adjustMobileMargin);
    window.addEventListener('DOMContentLoaded', adjustMobileMargin);
    // Re-adjust after fonts/images load
    window.addEventListener('load', adjustMobileMargin);
</script>

{% block admin_javascripts %}{% endblock %}

{% endblock %}
