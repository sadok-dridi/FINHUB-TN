{% extends 'admin/layout.html.twig' %}

{% block title %}Support & Safety Center - FINHUB{% endblock %}

{% block admin_stylesheets %}
<style>
    /* Support Center Header */
    .support-header-container {
        text-align: center;
        margin-bottom: 2.5rem;
    }
    
    .support-title {
        font-size: 2rem;
        font-weight: 600;
        color: #E5E7EB;
        margin-bottom: 0.5rem;
    }
    
    .support-subtitle {
        font-size: 0.95rem;
        color: #9CA3AF;
        margin-bottom: 2rem;
    }
    
    /* Support Navigation Tabs */
    .support-nav {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }
    
    .support-tab {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #9CA3AF;
        background: transparent;
        border: none;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
    }
    
    .support-tab:hover {
        color: #E5E7EB;
        background: rgba(255, 255, 255, 0.05);
    }
    
    .support-tab.active {
        background: rgba(139, 92, 246, 0.2); /* Soft purple background */
        color: #E5E7EB;
        border: 1px solid rgba(139, 92, 246, 0.3);
    }
    
    /* Tickets Section Header */
    .tickets-section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .section-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #E9D5FF;
        margin: 0;
    }
    
    .btn-refresh {
        background: transparent;
        border: none;
        color: #9CA3AF;
        cursor: pointer;
        padding: 0.5rem;
        border-radius: 50%;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .btn-refresh:hover {
        color: #E5E7EB;
        background: rgba(255, 255, 255, 0.1);
        transform: rotate(180deg);
    }
    
    /* Ticket List */
    .tickets-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    
    .ticket-card {
        display: flex;
        align-items: center;
        background: rgba(30, 27, 50, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        transition: all 0.2s ease;
        text-decoration: none;
    }
    
    .ticket-card:hover {
        background: rgba(40, 36, 65, 0.8);
        border-color: rgba(255, 255, 255, 0.1);
        transform: translateY(-2px);
    }
    
    .ticket-icon-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        margin-right: 1.25rem;
        flex-shrink: 0;
    }
    
    .status-icon-OPEN {
        background: rgba(139, 92, 246, 0.15);
        color: #8B5CF6;
    }
    
    .status-icon-RESOLVED, .status-icon-CLOSED {
        background: rgba(16, 185, 129, 0.15);
        color: #10B981;
    }
    
    .ticket-details {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    
    .ticket-subject {
        font-size: 1rem;
        font-weight: 500;
        color: #E5E7EB;
        margin: 0;
    }
    
    .ticket-meta {
        font-size: 0.8rem;
        color: #9CA3AF;
    }
    
    .ticket-badge {
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.35rem 0.75rem;
        border-radius: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .badge-OPEN {
        background: rgba(139, 92, 246, 0.15);
        color: #A78BFA;
        border: 1px solid rgba(139, 92, 246, 0.3);
    }
    
    .badge-RESOLVED, .badge-CLOSED {
        background: rgba(16, 185, 129, 0.15);
        color: #34D399;
        border: 1px solid rgba(16, 185, 129, 0.3);
    }
    
    .empty-state {
        text-align: center;
        padding: 3rem;
        color: #9CA3AF;
        background: rgba(30, 27, 50, 0.4);
        border-radius: 12px;
        border: 1px dashed rgba(255, 255, 255, 0.05);
    }

    @media (max-width: 768px) {
        .support-nav {
            gap: 0.5rem;
        }
        .support-tab {
            font-size: 0.8rem;
            padding: 0.4rem 0.8rem;
        }
        .ticket-card {
            padding: 1rem;
        }
        .ticket-header-left { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
        .tickets-section-header { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    }
</style>
{% endblock %}

{% block admin_content %}
<div class="page-container">
    
    <!-- Header Section -->
    <div class="support-header-container">
        <h1 class="support-title">Support & Safety Center</h1>
        <p class="support-subtitle">Manage user support tickets, system alerts, and compliance requests.</p>
        
        <div class="support-nav">
            <a href="#" class="support-tab active">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                Support Tickets
            </a>
            <a href="{{ path('app_admin_support_alerts') }}" class="support-tab">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                System Alerts
            </a>
            <a href="{{ path('app_admin_support_kyc') }}" class="support-tab">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M9 12l2 2 4-4"></path></svg>
                KYC Requests
            </a>
            <a href="{{ path('app_admin_support_kb') }}" class="support-tab">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                Knowledge Base
            </a>
        </div>
    </div>

    <!-- Tickets Section -->
    <div class="tickets-section-header">
        <h2 class="section-title">All Tickets</h2>
        <div class="header-actions">
            <!-- Refresh Button -->
            <button class="btn-refresh" onclick="window.location.reload();" title="Refresh Tickets">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
            </button>
        </div>
    </div>

    <div class="tickets-list">
        {% if tickets is empty %}
            <div class="empty-state">
                <p>No active tickets found.</p>
            </div>
        {% else %}
            {% for ticket in tickets %}
                <a href="{{ path('app_admin_support_details', {'id': ticket.id}) }}" class="ticket-card">
                    <div class="ticket-icon-wrapper status-icon-{{ ticket.status }}">
                        {% if ticket.status == 'OPEN' %}
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                        {% else %}
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                        {% endif %}
                    </div>
                    
                    <div class="ticket-details">
                        <h3 class="ticket-subject">{{ ticket.subject|default('No Subject') }}</h3>
                        <div class="ticket-meta">
                            #{{ ticket.id }} &bull; {{ ticket.priority|default('NORMAL')|upper }} &bull; {{ ticket.createdAt|date('M d') }}
                        </div>
                    </div>
                    
                    <div class="ticket-badge badge-{{ ticket.status }}">
                        {{ ticket.status }}
                    </div>
                </a>
            {% endfor %}
        {% endif %}
    </div>

</div>
{% endblock %}
