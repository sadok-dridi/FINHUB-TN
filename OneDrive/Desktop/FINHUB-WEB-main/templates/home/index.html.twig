{% extends 'base.html.twig' %}

{% block title %}FinHub - The Future of Finance{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Hero Overrides */
        .hero-section {
            padding-top: 100px; /* Offset fixed navbar */
            min-height: 90vh;
            display: flex;
            align-items: center;
            padding-bottom: 2rem;
        }

        @media (max-width: 768px) {
            .hero-section {
                height: 100vh;
                min-height: 100vh;
                padding-top: 70px; /* Slightly lower from navbar */
                padding-bottom: 2rem;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                gap: 1.5rem; /* Reduced gap for tighter layout */
            }
            .hero-title {
                font-size: 2.2rem !important; /* Smaller, professional app heading */
                line-height: 1.2 !important;
                letter-spacing: -0.5px;
                margin-bottom: 2rem !important; /* Added space between title and desc */
            }
            .hero-subtitle {
                font-size: 0.95rem !important; /* Smaller, crisp description */
                line-height: 1.5;
                margin-bottom: 1rem !important;
                padding: 0 1.5rem;
                color: rgba(255, 255, 255, 0.7) !important; /* Subtler text color */
            }
            .badge {
                 margin-bottom: 0 !important;
                 font-size: 0.8rem;
                 padding: 6px 12px !important;
            }
            .cta-buttons a.btn {
                 font-size: 0.95rem !important; /* Smaller buttons */
                 padding: 0.8rem 1.5rem !important; /* Less padding */
                 max-width: 300px !important; /* Narrower buttons */
            }
        }


        .stat-number {
            font-size: 2.5rem;
            font-weight: 800;
            color: white;
            display: block;
        }
        .stat-label {
            color: var(--color-text-secondary);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
    </style>
{% endblock %}

