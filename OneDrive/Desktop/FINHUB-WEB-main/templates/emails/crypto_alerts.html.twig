<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Crypto Alerts</title>
    <style>
        body { font-family: sans-serif; color: #333; margin: 20px; line-height: 1.5; }
        h1 { color: #8B5CF6; }
        .alert-box { padding: 15px; margin-bottom: 15px; border-radius: 8px; font-weight: 500; border-left: 5px solid; }
        .alert-buy { background: #ecfdf5; border-color: #10B981; color: #047857; }
        .alert-sell { background: #fef2f2; border-color: #EF4444; color: #B91C1C; }
        .alert-hold { background: #f3f4f6; border-color: #9ca3af; color: #4b5563; }
        .btn { display: inline-block; padding: 10px 20px; background: #8B5CF6; color: white; text-decoration: none; border-radius: 5px; margin-top: 10px; font-weight: bold; }
    </style>
</head>
<body>
    <h1>FinHub Trading Alerts</h1>
    <p>Hello {{ user.fullName|default(user.email) }},</p>
    <p>Our system has detected significant market movements that may present a trading opportunity:</p>
    
    {% for alert in alerts %}
        <div class="alert-box {% if alert.type == 'BUY' %}alert-buy{% elseif alert.type == 'SELL' %}alert-sell{% else %}alert-hold{% endif %}">
            <h3 style="margin-top:0;">{{ alert.name }} ({{ alert.symbol }}) : {{ alert.type }} SIGNAL</h3>
            <p style="font-size: 0.9em; font-style: italic; color: #666; margin-top: -10px;">{{ alert.description }}</p>
            <p>{{ alert.recommendation }} ({{ alert.change }}% in 24h)</p>
            <p><strong>Current Price:</strong> {{ alert.price }} USD</p>
        </div>
    {% endfor %}

    <p style="margin-top: 30px;">
        <a href="http://127.0.0.1:8000/user/twin/" class="btn">Open Simulator</a>
    </p>

    <p style="color: #666; font-size: 0.9em; margin-top: 40px; border-top: 1px solid #ccc; padding-top: 10px;">
        This is an automatic alert generated by the intelligent FinHub system.
    </p>
</body>
</html>
