{% block user_javascripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://unpkg.com/lightweight-charts/dist/lightweight-charts.standalone.production.js"></script>

<script>
    // Tab Switching
    function switchTab(event, tabId) {
        event.preventDefault();
        document.querySelectorAll('.tab-link').forEach(link => link.classList.remove('active'));
        event.target.classList.add('active');

        document.querySelectorAll('.tab-content').forEach(content => {
            content.style.display = 'none';
        });

        document.getElementById(tabId).style.display = 'block';

        if (tabId === 'tabMarket' && !chartInitialized) {
            chartInitialized = true;
            setTimeout(() => {
                initMarketChart();
            }, 300); // Increased timeout to ensure container is fully rendered and sized
        } else if (tabId === 'tabMarket' && chartInitialized && lwChart) {
            // Force a resize calculation when tabbing back to it
            setTimeout(() => {
                const container = document.getElementById('lightweight-chart');
                if (container && container.clientWidth > 0) {
                    lwChart.resize(container.clientWidth, container.clientHeight);
                    lwChart.timeScale().fitContent();
                }
            }, 300);
        }
    }

    // Define elements
    let incomeSlider, incomeInput, expenseSlider, expenseInput, goalInput;
    let projectionChartInstance = null;
    let chartInitialized = false;
    let lwChart = null;
    let candleSeries = null;
    let currentAssetPrice = 67396.47;
    let currentAssetSymbol = 'BTC';
    let currentAssetId = 'bitcoin';
    let currentChartData = [];
    
    // Inject Portfolio data
    let userPortfolio = {{ portfolio|json_encode|raw }};
    let userWalletBalance = {{ walletBalance|number_format(2, '.', '') }};
    let usdToTndRate = {{ usdToTndRate }};

    document.addEventListener('DOMContentLoaded', () => {
        // --- Financial Health Logic ---
        incomeSlider = document.getElementById('incomeSlider');
        incomeInput = document.getElementById('incomeInput');
        expenseSlider = document.getElementById('expenseSlider');
        expenseInput = document.getElementById('expenseInput');
        goalInput = document.getElementById('goalInput');

        function syncInputs() {
            if (!incomeSlider) return;
            incomeSlider.addEventListener('input', () => {
                incomeInput.value = incomeSlider.value;
                runSimulation();
            });
            incomeInput.addEventListener('input', () => {
                incomeSlider.value = incomeInput.value;
                runSimulation();
            });
            expenseSlider.addEventListener('input', () => {
                expenseInput.value = expenseSlider.value;
                runSimulation();
            });
            expenseInput.addEventListener('input', () => {
                expenseSlider.value = expenseInput.value;
                runSimulation();
            });
            goalInput.addEventListener('input', () => {
                runSimulation();
            });
        }
        
        syncInputs();
        // Initial Run
        runSimulation();
        updateTradePanel();
    });

    function resetScenarios() {
        incomeSlider.value = {{ income|default(1500) }};
        incomeInput.value = {{ income|default(1500) }};
        expenseSlider.value = {{ expenses|default(1200) }};
        expenseInput.value = {{ expenses|default(1200) }};
        goalInput.value = {{ goal|default(10000) }};
        runSimulation();
    }

    function runSimulation() {
        if (!incomeInput) return;
        const inc = parseFloat(incomeInput.value) || 0;
        const exp = parseFloat(expenseInput.value) || 0;
        const goal = parseFloat(goalInput.value) || 0;

        // 1. Calculate Score (Java Logic: calculateHealthScore)
        let score = 0;
        if (inc > 0) {
            let savings = inc - exp;
            if (savings >= 0) {
                score = Math.floor((savings / inc) * 100);
                if (exp < (inc * 0.5)) {
                    score += 10;
                }
                score = Math.min(score, 100);
            }
        }

        const gauge = document.getElementById('healthGauge');
        const scoreSpan = document.getElementById('healthScore');
        const statusText = document.getElementById('healthStatusText');
        
        if (scoreSpan) scoreSpan.innerText = score + '%';
        if (gauge) gauge.className = 'gauge';
        if (statusText) statusText.className = 'health-status';

        // Java Logic: getHealthStatus & getHealthColor
        if (score >= 60) {
            if (gauge) gauge.classList.add('green');
            if (statusText) { statusText.classList.add('status-green'); statusText.innerText = 'Healthy'; }
        } else if (score >= 30) {
            if (gauge) gauge.classList.add('yellow');
            if (statusText) { statusText.classList.add('status-yellow'); statusText.innerText = 'Medium Risk'; }
        } else {
            if (gauge) gauge.classList.add('red');
            if (statusText) { statusText.classList.add('status-red'); statusText.innerText = 'High Risk'; }
        }

        // 2. Generate Chart Data (Java Logic: runSimulation)
        const net = inc - exp;
        const labels = [];
        const data = [];
        let currentMonth = new Date();
        let currentSavings = 0; 

        for (let i = 0; i < 12; i++) {
            currentMonth.setMonth(currentMonth.getMonth() + 1);
            labels.push(currentMonth.toLocaleString('default', { month: 'short' }));
            currentSavings += net; 
            data.push(currentSavings);
        }

        updateProjectionChart(labels, data);

        // 3. Update Feedback Text (Java Logic: generateKeyInsights)
        let insightHtml = '🧠 **Financial Twin Analysis**<br><br>';
        
        let savingsRatio = (inc > 0) ? (net / inc) * 100 : 0;
        
        if (net <= 0) {
            insightHtml += '⚠️ **Critical Warning**: You are spending more than you earn. Immediate action required: Reduce discretionary spending or find new income sources.<br><br>';
        } else if (savingsRatio < 20) {
            insightHtml += `⚠️ **Low Savings Rate**: You're saving only ${savingsRatio.toFixed(1)}% of your income. Try to aim for at least 20% by cutting small daily expenses.<br><br>`;
        } else {
            insightHtml += `✅ **Good Savings Habit**: You are saving ${savingsRatio.toFixed(1)}% of your income. Keep it up!<br><br>`;
        }

        if (goal > 0 && net > 0) {
            let monthsToGoal = Math.ceil(goal / net);
            if (monthsToGoal > 60) {
                insightHtml += `📉 **Long Road Ahead**: At this rate, it will take ${monthsToGoal} months to reach your goal. Consider adjusting your goal or increasing your monthly savings.<br><br>`;
            } else {
                insightHtml += `🎯 **Goal Within Reach**: You can reach your savings goal in approx. ${monthsToGoal} months.<br><br>`;
            }
        }

        if (exp > (inc * 0.7)) {
            let expPct = Math.floor((exp / inc) * 100);
            insightHtml += `💡 **Tip**: Your recurring expenses are quite high (${expPct}%). Review your subscriptions and rent/utilities to find potential savings.`;
        } else {
            insightHtml += '💡 **Tip**: Your expense management is solid. Consider investing your surplus savings for better growth.';
        }

        // Format asterisks as bold tags
        insightHtml = insightHtml.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');

        let feedbackEl = document.getElementById('twinFeedback');
        if (feedbackEl) feedbackEl.innerHTML = insightHtml;
    }

    function updateProjectionChart(labels, data) {
        const canvas = document.getElementById('projectionChart');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        
        if (projectionChartInstance) {
            projectionChartInstance.destroy();
        }

        projectionChartInstance = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Projected Savings',
                    data: data,
                    borderColor: '#F97316', // Orange line
                    backgroundColor: 'rgba(249, 115, 22, 0.1)',
                    borderWidth: 2,
                    pointRadius: 0,
                    pointHoverRadius: 4,
                    fill: false,
                    tension: 0.1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { mode: 'index', intersect: false }
                },
                scales: {
                    x: {
                        grid: { color: 'rgba(255,255,255,0.05)' },
                        ticks: { color: '#9CA3AF', font: { size: 10 } }
                    },
                    y: {
                        grid: { color: 'rgba(255,255,255,0.05)' },
                        ticks: { color: '#9CA3AF', font: { size: 10 } },
                        beginAtZero: true
                    }
                }
            }
        });
    }

    // --- Market Simulator Logic ---
    function initMarketChart() {
        const container = document.getElementById('lightweight-chart');
        if (!container) return;
        
        lwChart = LightweightCharts.createChart(container, {
            width: container.clientWidth,
            height: container.clientHeight,
            layout: {
                background: { type: 'solid', color: '#151120' },
                textColor: '#9CA3AF',
            },
            grid: {
                vertLines: { color: 'rgba(255,255,255,0.05)' },
                horzLines: { color: 'rgba(255,255,255,0.05)' },
            },
            crosshair: {
                mode: LightweightCharts.CrosshairMode.Normal,
            },
            rightPriceScale: {
                borderColor: 'rgba(255,255,255,0.1)',
            },
            timeScale: {
                borderColor: 'rgba(255,255,255,0.1)',
                timeVisible: true,
            },
        });

        candleSeries = lwChart.addCandlestickSeries({
            upColor: '#10B981',
            downColor: '#EF4444',
            borderDownColor: '#EF4444',
            borderUpColor: '#10B981',
            wickDownColor: '#EF4444',
            wickUpColor: '#10B981',
        });

        if (currentChartData.length > 0) {
            if (candleSeries) {
                candleSeries.setData(currentChartData);
                setTimeout(() => {
                    if (lwChart && lwChart.timeScale) {
                        lwChart.timeScale().fitContent();
                    }
                }, 50);
            }
        } else if (currentAssetId) {
            fetchAndRenderChartData(currentAssetId);
        }

        new ResizeObserver(entries => {
            if (entries.length === 0 || entries[0].target !== container) { return; }
            const newRect = entries[0].contentRect;
            // Prevent resize crash if dimensions are 0
            if (newRect.width > 0 && newRect.height > 0) {
                lwChart.resize(newRect.width, newRect.height);
            }
        }).observe(container);
    }

    function selectAsset(id, name, symbol, price, change, iconSrc) {
        // Update UI
        document.querySelectorAll('.asset-item').forEach(el => el.classList.remove('active'));
        if (window.event && window.event.currentTarget) {
            window.event.currentTarget.classList.add('active');
        }

        document.getElementById('chartSymbol').innerText = name.toLowerCase();
        document.getElementById('chartPrice').innerHTML = price + ' TND <span style="font-size: 0.7rem;">USD</span>';
        
        const changeEl = document.getElementById('chartChange');
        changeEl.innerText = change + '%';
        if (change.startsWith('+')) {
            changeEl.className = 'chart-change change-up';
        } else {
            changeEl.className = 'chart-change change-down';
        }

        currentAssetPrice = parseFloat(price.toString().replace(/,/g, ''));
        currentAssetSymbol = symbol;
        currentAssetId = id;
        updateTradePanel();
        updateTradeEst();

        if (chartInitialized && candleSeries) {
            fetchAndRenderChartData(id);
        }
    }

    async function fetchAndRenderChartData(assetId) {
        try {
            let symbol = currentAssetSymbol.toUpperCase();

            // Fetch real OHLC data from CryptoCompare (1h candles, up to 200 hours)
            const response = await fetch(`https://min-api.cryptocompare.com/data/v2/histohour?fsym=${symbol}&tsym=USD&limit=200`);
            
            if (!response.ok) {
                console.error("Failed to fetch data for:", symbol);
                return;
            }
            
            const payload = await response.json();
            
            if (payload.Response !== 'Success' || !payload.Data || !payload.Data.Data) {
                console.error("CryptoCompare API Error:", payload.Message);
                // Fallback for unsupported assets on this API
                generateFallbackData();
                return;
            }
            
            const formattedData = payload.Data.Data.map(item => {
                return {
                    time: item.time, // CryptoCompare returns time in seconds
                    open: parseFloat(item.open),
                    high: parseFloat(item.high),
                    low: parseFloat(item.low),
                    close: parseFloat(item.close)
                };
            }).filter(item => !isNaN(item.open) && !isNaN(item.high) && !isNaN(item.low) && !isNaN(item.close) && !isNaN(item.time));

            if (formattedData.length === 0) {
                console.error("No valid chart data returned");
                generateFallbackData();
                return;
            }

            // Make sure array is sorted by time and strictly increasing
            formattedData.sort((a, b) => a.time - b.time);
            
            // Remove duplicates
            const uniqueData = [];
            formattedData.forEach((item, index) => {
                if (index === 0 || item.time > formattedData[index - 1].time) {
                    uniqueData.push(item);
                }
            });

            currentChartData = uniqueData;

            if (candleSeries) {
                candleSeries.setData(uniqueData);
                // Adjust scale
                setTimeout(() => {
                    if (lwChart && lwChart.timeScale) {
                        lwChart.timeScale().fitContent();
                    }
                }, 50);
            }
        } catch (e) {
            console.error("Failed to fetch chart data:", e);
            generateFallbackData();
        }
    }

    function generateFallbackData() {
        if (!candleSeries) return;
        const fallbackData = [];
        let time = Math.floor(Date.now() / 1000) - (200 * 3600);
        let lastClose = currentAssetPrice * 0.95; 

        for (let i = 0; i < 200; i++) {
            const volatility = currentAssetPrice * 0.005;
            const open = lastClose + (Math.random() * volatility - volatility/2);
            const close = open + (Math.random() * volatility - volatility/2);
            const high = Math.max(open, close) + (Math.random() * (volatility/2));
            const low = Math.min(open, close) - (Math.random() * (volatility/2));
            
            fallbackData.push({ time: time, open: open, high: high, low: low, close: close });
            lastClose = close;
            time += 3600;
        }

        currentChartData = fallbackData;
        if (candleSeries) {
            candleSeries.setData(fallbackData);
            setTimeout(() => {
                if (lwChart && lwChart.timeScale) {
                    lwChart.timeScale().fitContent();
                }
            }, 50);
        }
    }


    function updateTradePanel() {
        const ownedElement = document.getElementById('posOwned');
        const avgElement = document.getElementById('posAvg');
        const availBuyElement = document.getElementById('tradeAvailBuy');
        const walletDisplay = document.getElementById('walletBalanceDisplay');

        walletDisplay.innerText = userWalletBalance.toFixed(2) + ' TND';

        let ownedQty = 0;
        let avgCost = 0;
        if (userPortfolio[currentAssetId]) {
            ownedQty = userPortfolio[currentAssetId].quantity;
            avgCost = userPortfolio[currentAssetId].averageCost;
        }

        ownedElement.innerText = ownedQty.toFixed(6) + ' Units';
        avgElement.innerText = avgCost.toFixed(2) + ' USD';

        // How many units they can buy with current balance
        const maxBuy = userWalletBalance / (currentAssetPrice * usdToTndRate);
        availBuyElement.innerText = maxBuy.toFixed(6) + ' Units';

        updateTradeEst();
    }

    function updateTradeEst() {
        const amt = parseFloat(document.getElementById('tradeAmount').value) || 0;
        const est = amt * currentAssetPrice * usdToTndRate;
        document.getElementById('tradeEst').innerText = est.toFixed(2) + ' TND';
    }

    async function executeTrade(mode, btnElement) {
        const amount = parseFloat(document.getElementById('tradeAmount').value) || 0;
        if (amount <= 0) {
            alert('Please enter a valid amount');
            return;
        }

        const originalText = btnElement.innerText;
        btnElement.innerText = 'Processing...';
        btnElement.disabled = true;

        try {
            const response = await fetch('/user/twin/trade', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    symbol: currentAssetId,
                    type: mode.toUpperCase(),
                    amount: amount,
                    price: currentAssetPrice
                })
            });

            const data = await response.json();

            if (data.success) {
                alert(data.message);
                // Update local state
                userWalletBalance = parseFloat(data.newBalance);
                if (data.portfolio) {
                    userPortfolio[currentAssetId] = data.portfolio;
                } else {
                    delete userPortfolio[currentAssetId];
                }
                
                // Reset amount
                document.getElementById('tradeAmount').value = '0.0';
                
                // Update UI
                updateTradePanel();
            } else {
                alert('Trade failed: ' + data.message);
            }
        } catch (err) {
            console.error(err);
            alert('An error occurred during the trade.');
        } finally {
            btnElement.innerText = originalText;
            btnElement.disabled = false;
        }
    }

    // --- Expense Tracker Logic ---
    let currentExpenseId = null;

    function applyExpenseFilters() {
        const list = document.getElementById('expenseList');
        const rows = Array.from(list.querySelectorAll('.et-scan-item'));
        const searchInput = document.getElementById('expenseSearchInput');
        const sortSelect = document.getElementById('expenseSort');
        const directionSelect = document.getElementById('expenseDirection');
        const noResults = document.getElementById('expenseNoResults');

        if (!list || !searchInput || !sortSelect || !directionSelect || rows.length === 0) {
            return;
        }

        const search = searchInput.value.trim().toLowerCase();
        const sort = sortSelect.value;
        const direction = directionSelect.value;

        const filteredRows = rows.filter((row) => {
            const merchant = row.dataset.merchant || '';
            const amount = row.dataset.amount || '';
            const date = row.dataset.date || '';
            const haystack = `${merchant} ${amount} ${date}`.toLowerCase();
            const match = haystack.includes(search);

            row.style.display = match ? 'flex' : 'none';
            return match;
        });

        filteredRows.sort((a, b) => {
            let comparison = 0;

            if (sort === 'merchant') {
                comparison = (a.dataset.merchant || '').localeCompare(b.dataset.merchant || '');
            } else if (sort === 'amount') {
                comparison = parseFloat(a.dataset.amount || '0') - parseFloat(b.dataset.amount || '0');
            } else {
                comparison = (a.dataset.date || '').localeCompare(b.dataset.date || '');
            }

            return direction === 'asc' ? comparison : -comparison;
        });

        filteredRows.forEach((row) => list.appendChild(row));
        noResults.style.display = filteredRows.length === 0 ? 'block' : 'none';
    }

    document.getElementById('expenseSearchInput')?.addEventListener('input', applyExpenseFilters);
    document.getElementById('expenseSort')?.addEventListener('change', applyExpenseFilters);
    document.getElementById('expenseDirection')?.addEventListener('change', applyExpenseFilters);
    document.addEventListener('DOMContentLoaded', applyExpenseFilters);

    function openExpenseModal() {
        currentExpenseId = null;
        document.querySelectorAll('.text-danger.form-error').forEach(el => el.remove());
        document.getElementById('modalTitle').innerText = 'Add New Expense';
        document.getElementById('modalMerchant').value = '';
        document.getElementById('modalTotalAmount').value = '';
        document.getElementById('modalItemsContainer').innerHTML = '';
        addModalItemRow();
        document.getElementById('expenseModal').style.display = 'flex';
    }

    function openEditExpenseModal(id) {
        currentExpenseId = id;
        document.querySelectorAll('.text-danger.form-error').forEach(el => el.remove());
        document.getElementById('modalTitle').innerText = 'Edit Expense';
        
        // Find expense data from DOM
        const row = document.getElementById('expense-row-' + id);
        if (!row) return;

        const merchant = row.querySelector('.et-scan-name').innerText;
        const amountText = row.querySelector('.et-scan-amount').innerText;
        const amount = parseFloat(amountText);

        document.getElementById('modalMerchant').value = merchant;
        document.getElementById('modalTotalAmount').value = amount.toFixed(2);
        
        const container = document.getElementById('modalItemsContainer');
        container.innerHTML = '';

        const itemElements = row.querySelectorAll('.expense-item-row');
        if (itemElements.length > 0) {
            itemElements.forEach(el => {
                const name = el.getAttribute('data-name');
                const price = parseFloat(el.getAttribute('data-price'));
                addModalItemRow(name, price);
            });
        } else {
            addModalItemRow();
        }

        document.getElementById('expenseModal').style.display = 'flex';
    }

    function closeExpenseModal() {
        document.getElementById('expenseModal').style.display = 'none';
        currentExpenseId = null;
    }

    function addModalItemRow(name = '', price = '') {
        const container = document.getElementById('modalItemsContainer');
        const rowId = 'item-row-' + Date.now() + Math.floor(Math.random() * 100);
        const priceVal = price !== '' ? parseFloat(price).toFixed(2) : '';
        const rowHtml = `
            <div id="${rowId}" style="display: flex; gap: 8px; align-items: center;">
                <input type="text" class="modal-item-name" placeholder="Item Name" value="${name}" style="flex: 1; padding: 8px; border-radius: 6px; background: #151120; color: white; border: 1px solid rgba(255,255,255,0.1); box-sizing: border-box; font-size: 0.85rem;">
                <input type="number" class="modal-item-price" placeholder="Price" step="0.01" value="${priceVal}" style="width: 80px; padding: 8px; border-radius: 6px; background: #151120; color: white; border: 1px solid rgba(255,255,255,0.1); box-sizing: border-box; font-size: 0.85rem;" oninput="updateModalTotal()">
                <button type="button" onclick="document.getElementById('${rowId}').remove(); updateModalTotal();" style="background: none; border: none; color: #EF4444; cursor: pointer; padding: 8px;"><i class="fas fa-times"></i></button>
            </div>
        `;
        container.insertAdjacentHTML('beforeend', rowHtml);
    }

    function updateModalTotal() {
        const prices = document.querySelectorAll('.modal-item-price');
        let total = 0;
        prices.forEach(p => {
            const val = parseFloat(p.value);
            if (!isNaN(val)) total += val;
        });
        if (total > 0) {
            document.getElementById('modalTotalAmount').value = total.toFixed(2);
        }
    }

    async function submitExpenseModal() {
        const merchantInput = document.getElementById('modalMerchant');
        const amountInput = document.getElementById('modalTotalAmount');
        const merchant = merchantInput.value.trim();
        const amountVal = amountInput.value.trim();
        const amount = amountVal === '' ? null : parseFloat(amountVal);

        // Clear previous errors
        document.querySelectorAll('.text-danger.form-error').forEach(el => el.remove());
        
        const items = [];
        const itemRows = document.getElementById('modalItemsContainer').children;
        for (let row of itemRows) {
            if (!row.id || !row.id.startsWith('item-row-')) continue;
            const nameInput = row.querySelector('.modal-item-name');
            const priceInput = row.querySelector('.modal-item-price');
            if (!nameInput || !priceInput) continue;
            const name = nameInput.value.trim();
            const priceVal = priceInput.value.trim();
            const price = priceVal === '' ? null : parseFloat(priceVal);
            items.push({ name, price: price, rowId: row.id });
        }

        const btn = document.getElementById('btnSubmitExpense');
        const originalText = btn.innerText;
        btn.innerText = 'Saving...';
        btn.disabled = true;

        try {
            let endpoint = '/user/twin/expense/add';
            let method = 'POST';
            if (currentExpenseId) {
                endpoint = '/user/twin/expense/edit/' + currentExpenseId;
                method = 'PUT';
            }

            const response = await fetch(endpoint, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ merchant, amount, items: items.map(i => ({ name: i.name, price: i.price })) })
            });

            const data = await response.json();

            if (data.success) {
                window.location.reload();
            } else {
                if (data.errors) {
                    for (const [field, message] of Object.entries(data.errors)) {
                        if (field === 'merchant') {
                            const errorSpan = document.createElement('span');
                            errorSpan.className = 'text-danger form-error';
                            errorSpan.style.color = '#EF4444';
                            errorSpan.style.fontSize = '0.85rem';
                            errorSpan.style.marginTop = '4px';
                            errorSpan.style.display = 'block';
                            errorSpan.innerText = message;
                            merchantInput.parentNode.appendChild(errorSpan);
                        } else if (field === 'amount') {
                            const errorSpan = document.createElement('span');
                            errorSpan.className = 'text-danger form-error';
                            errorSpan.style.color = '#EF4444';
                            errorSpan.style.fontSize = '0.85rem';
                            errorSpan.style.marginTop = '4px';
                            errorSpan.style.display = 'block';
                            errorSpan.innerText = message;
                            amountInput.parentNode.appendChild(errorSpan);
                        } else if (field.startsWith('items.')) {
                                // field is something like "items.0.name"
                                const parts = field.split('.');
                                const index = parseInt(parts[1]);
                                const subfield = parts[2];
                                
                                const itemRows = Array.from(document.getElementById('modalItemsContainer').children).filter(child => !child.classList.contains('form-error'));
                                if (index >= 0 && index < itemRows.length) {
                                    const row = itemRows[index];
                                    const targetInput = subfield === 'name' ? row.querySelector('.modal-item-name') : row.querySelector('.modal-item-price');
                                    if (targetInput) {
                                        targetInput.style.border = '1px solid #EF4444';
                                        
                                        const rowError = document.createElement('div');
                                        rowError.className = 'text-danger form-error';
                                        rowError.style.color = '#EF4444';
                                        rowError.style.fontSize = '0.75rem';
                                        rowError.style.marginTop = '2px';
                                        rowError.style.marginLeft = '4px';
                                        rowError.innerText = message;
                                        row.insertAdjacentElement('afterend', rowError);
                                    }
                                }
                        }
                    }
                } else {
                    alert(data.message || 'An error occurred.');
                }
            }
        } catch (err) {
            console.error(err);
            alert('A network error occurred.');
        } finally {
            btn.innerText = originalText;
            btn.disabled = false;
        }
    }

    async function deleteExpense(id) {
        if (!confirm('Are you sure you want to delete this expense?')) return;

        try {
            const response = await fetch('/user/twin/expense/' + id, {
                method: 'DELETE'
            });

            const data = await response.json();
            if (data.success) {
                const row = document.getElementById('expense-row-' + id);
                if (row) {
                    const amountText = row.querySelector('.et-scan-amount').innerText;
                    const amount = parseFloat(amountText);
                    updateTotalExpenses(amount, false);
                    row.remove();
                    applyExpenseFilters();
                }
            } else {
                alert('Error deleting expense: ' + data.message);
            }
        } catch (e) {
            console.error(e);
            alert('Error deleting expense');
        }
    }

    function toggleExpenseDetails(id) {
        const detailsDiv = document.getElementById('expense-details-' + id);
        if (detailsDiv) {
            detailsDiv.style.display = detailsDiv.style.display === 'none' ? 'block' : 'none';
        }
    }

    function appendExpenseRow(exp) {
        const list = document.getElementById('expenseList');
        const formattedAmount = parseFloat(exp.amount).toFixed(2);
        const items = exp.items || [];
        
        let itemsHtml = '';
        if (items.length === 0) {
            itemsHtml = `<div style="color: #6B7280; font-size: 0.8rem;">- No individual items found.</div>`;
        } else {
            items.forEach(item => {
                itemsHtml += `
                    <div class="expense-item-row" data-name="${item.name}" data-price="${parseFloat(item.price).toFixed(2)}" style="display: flex; justify-content: space-between; font-size: 0.85rem; margin-bottom: 4px; color: #D1D5DB;">
                        <span>- ${item.name}</span>
                        <span>${parseFloat(item.price).toFixed(2)} TND</span>
                    </div>
                `;
            });
        }

        const html = `
            <div class="et-scan-item" id="expense-row-${exp.id}" data-merchant="${String(exp.merchant).toLowerCase()}" data-amount="${exp.amount}" data-date="${exp.date}" style="cursor: pointer;" onclick="toggleExpenseDetails(${exp.id})">
                <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
                    <div class="et-scan-left">
                        <div class="et-scan-icon"><i class="fas fa-shopping-bag"></i></div>
                        <div class="et-scan-info">
                            <div class="et-scan-name">${exp.merchant}</div>
                            <div class="et-scan-date">${exp.date}</div>
                        </div>
                    </div>
                    <div class="et-scan-right" style="display: flex; gap: 8px; align-items: center;">
                        <div class="et-scan-amount">${formattedAmount} TND</div>
                        <button class="btn-trade buy" style="padding: 6px 12px; font-size: 0.8rem; width: auto; background: rgba(16, 185, 129, 0.2); color: #10B981;" onclick="event.stopPropagation(); openEditExpenseModal(${exp.id})">
                            <i class="fas fa-edit"></i>
                        </button>
                        <button class="btn-trade sell" style="padding: 6px 12px; font-size: 0.8rem; width: auto; background: rgba(239, 68, 68, 0.2); color: #EF4444;" onclick="event.stopPropagation(); deleteExpense(${exp.id})">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
                <div class="expense-details" id="expense-details-${exp.id}" style="display: none; width: 100%; margin-top: 16px; padding-top: 16px; border-top: 1px solid rgba(255,255,255,0.05);">
                    <div style="color: #9CA3AF; font-size: 0.85rem; margin-bottom: 8px;">Items (${items.length})</div>
                    ${itemsHtml}
                </div>
            </div>
        `;
        list.insertAdjacentHTML('afterbegin', html);
        applyExpenseFilters();
    }

    function updateTotalExpenses(amount, isAdding) {
        const titleEl = document.getElementById('totalExpensesVal');
        if (titleEl) {
            let current = parseFloat(titleEl.innerText) || 0;
            current = isAdding ? current + parseFloat(amount) : current - parseFloat(amount);
            if (current < 0) current = 0;
            titleEl.innerText = current.toFixed(2) + ' TND';
        }
    }

    function openEmailModal() {
        document.getElementById('emailModalAddress').value = '{{ app.user.email|default('') }}';
        document.getElementById('emailModalMessage').value = '';
        document.getElementById('emailModal').style.display = 'flex';
    }

    function closeEmailModal() {
        document.getElementById('emailModal').style.display = 'none';
        document.getElementById('btnSubmitEmail').innerText = 'Send';
        document.getElementById('btnSubmitEmail').disabled = false;
    }

    async function submitEmailModal() {
        const email = document.getElementById('emailModalAddress').value;
        const msg = document.getElementById('emailModalMessage').value;
        
        if(!email) {
            alert('Please enter an email address');
            return;
        }

        const btn = document.getElementById('btnSubmitEmail');
        btn.innerText = 'Sending...';
        btn.disabled = true;

        try {
            const response = await fetch('{{ path('app_user_twin_expense_email') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email: email, message: msg })
            });
            const data = await response.json();
            if(data.success) {
                alert(data.message);
                closeEmailModal();
            } else {
                alert('Error: ' + data.message);
                btn.innerText = 'Send';
                btn.disabled = false;
            }
        } catch(e) {
            console.error(e);
            alert('Error sending email');
            btn.innerText = 'Send';
            btn.disabled = false;
        }
    }
</script>
{% endblock %}
