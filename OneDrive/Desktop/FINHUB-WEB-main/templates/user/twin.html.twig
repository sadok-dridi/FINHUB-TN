{% extends 'user/layout.html.twig' %}

{% block title %}Financial Twin & Market Simulation - FinHub{% endblock %}

{% block user_stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    /* Headers & Layout */
    .twin-header {
        margin-bottom: 24px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .twin-title {
        font-size: 1.8rem;
        font-weight: 600;
        color: #F3F4F6;
        margin: 0;
        letter-spacing: -0.5px;
    }
    .twin-subtitle {
        font-size: 0.95rem;
        color: #9CA3AF;
        margin: 0;
    }

    /* Tabs Navigation */
    .twin-tabs {
        display: flex;
        gap: 16px;
        margin-bottom: 30px;
        align-items: center;
    }
    .tab-link {
        color: #9CA3AF;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        padding: 8px 20px;
        border-radius: 20px;
        border: 1px solid transparent;
        transition: all 0.2s ease;
    }
    .tab-link:hover {
        color: #E5E7EB;
    }
    .tab-link.active {
        color: #fff;
        border-color: rgba(255, 255, 255, 0.1);
        background: rgba(30, 27, 46, 0.6);
        box-shadow: inset 0 0 0 1px rgba(139, 92, 246, 0.5); /* Purple accent */
    }

    /* Shared Panel Styles */
    .panel {
        background: rgba(20, 18, 35, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 20px;
    }
    .panel-title {
        font-size: 1rem;
        font-weight: 600;
        color: #F3F4F6;
        margin-bottom: 16px;
    }

    /* --- Financial Health Tab Layout --- */
    .fh-layout {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }
    .fh-sidebar {
        width: 300px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
    .fh-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 20px;
        min-width: 400px;
    }

    /* Scenarios Form */
    .scenario-group {
        margin-bottom: 16px;
    }
    .scenario-label {
        display: block;
        color: #D1D5DB;
        font-size: 0.85rem;
        margin-bottom: 8px;
    }
    .scenario-slider {
        width: 100%;
        accent-color: #8B5CF6;
        margin-bottom: 8px;
    }
    .scenario-input {
        width: 100%;
        background: rgba(30, 27, 46, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 10px;
        color: #fff;
        font-size: 0.95rem;
        outline: none;
    }
    .scenario-input:focus { border-color: #8B5CF6; }

    .btn-run {
        background: linear-gradient(135deg, #A855F7, #D946EF);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px;
        font-weight: 600;
        width: 100%;
        cursor: pointer;
        transition: opacity 0.2s;
        margin-bottom: 12px;
    }
    .btn-run:hover { opacity: 0.9; }

    .btn-reset {
        background: transparent;
        color: #9CA3AF;
        border: none;
        width: 100%;
        font-size: 0.85rem;
        cursor: pointer;
    }
    .btn-reset:hover { color: #E5E7EB; text-decoration: underline; }

    /* Health Score Gauge */
    .health-score-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        padding: 20px 0;
    }
    .gauge {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        border: 4px solid rgba(255, 255, 255, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.2rem;
        position: relative;
    }
    /* Dynamic colored border via inline style or classes later */
    .gauge.red { border-top-color: #EF4444; border-right-color: #EF4444; color: #fff; }
    .gauge.yellow { border-top-color: #F59E0B; border-right-color: #F59E0B; color: #fff; }
    .gauge.green { border-top-color: #10B981; border-right-color: #10B981; color: #fff; }

    .health-status {
        font-weight: 600;
        font-size: 1rem;
    }
    .status-red { color: #EF4444; }
    .status-yellow { color: #F59E0B; }
    .status-green { color: #10B981; }

    /* Chart & Feedback */
    .chart-container {
        height: 300px;
        width: 100%;
    }
    
    .feedback-box {
        background: rgba(30, 27, 46, 0.4);
        padding: 16px;
        border-radius: 8px;
        color: #D1D5DB;
        font-size: 0.9rem;
        line-height: 1.6;
    }
    .feedback-box strong { color: #E9D5FF; }

    /* --- Market Simulator Tab Layout --- */
    .ms-layout {
        display: flex;
        gap: 20px;
        height: 600px;
    }
    .ms-assets {
        width: 250px;
        display: flex;
        flex-direction: column;
        overflow-y: auto;
    }
    .asset-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.2s;
    }
    .asset-item:hover, .asset-item.active { background: rgba(255, 255, 255, 0.05); }
    .asset-item.active { border-left: 3px solid #10B981; }
    .asset-icon {
        width: 32px; height: 32px; border-radius: 50%; background: white;
        display: flex; align-items: center; justify-content: center; overflow: hidden;
    }
    .asset-icon img { width: 100%; height: 100%; object-fit: contain; }
    .asset-name { color: #F3F4F6; font-size: 0.95rem; }

    .ms-chart {
        flex: 1;
        display: flex;
        flex-direction: column;
        position: relative;
    }
    .ms-chart-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }
    .chart-symbol { font-size: 1.2rem; font-weight: 600; color: #fff; }
    .chart-price { font-size: 1.2rem; color: #D1D5DB; }
    .chart-change { font-size: 0.9rem; font-weight: 500; }
    .change-up { color: #10B981; }
    .change-down { color: #EF4444; }

    .ai-badge {
        position: absolute;
        top: 0; right: 0;
        background: rgba(30, 27, 46, 0.8);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 4px 10px;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #A78BFA;
    }

    #lightweight-chart {
        flex: 1;
        width: 100%;
        min-height: 450px;
        background: #151120;
    }

    .ms-trade {
        width: 250px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    .trade-tabs { display: flex; gap: 10px; margin-bottom: 10px; }
    .btn-trade {
        flex: 1; padding: 8px; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; color: white;
    }
    .btn-trade.buy { background: #10B981; }
    .btn-trade.buy:hover { opacity: 0.9; }
    .btn-trade.sell { background: #EF4444; }
    .btn-trade.sell:hover { opacity: 0.9; }
    .btn-trade.inactive { background: rgba(255,255,255,0.1); color: #9CA3AF; }

    .trade-field {
        background: rgba(30, 27, 46, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        padding: 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .trade-field input {
        background: transparent; border: none; color: #fff; outline: none; width: 60%; font-size: 0.95rem;
    }
    .trade-field span { color: #6B7280; font-size: 0.8rem; }
    
    .trade-info-row { display: flex; justify-content: space-between; color: #9CA3AF; font-size: 0.85rem; margin-top: 4px; }
    .trade-info-val { color: #D1D5DB; }

    .wallet-box {
        background: rgba(16, 185, 129, 0.05);
        border: 1px solid rgba(16, 185, 129, 0.2);
        border-radius: 8px;
        padding: 12px;
        margin-top: auto;
    }
    .wallet-box-title { color: #10B981; font-size: 0.8rem; margin-bottom: 4px; }
    .wallet-box-val { color: #fff; font-size: 1.1rem; font-weight: 600; }

    /* --- Expense Tracker Tab Layout --- */
    .et-top-boxes {
        display: flex;
        gap: 20px;
        margin-bottom: 24px;
    }
    .et-box {
        flex: 1;
        background: rgba(20, 18, 35, 0.6);
        border: 1px solid #8B5CF6; /* Purple border exactly like image */
        border-radius: 12px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .et-box-title { color: #9CA3AF; font-size: 0.85rem; margin-bottom: 8px; }
    .et-box-val { color: #F3F4F6; font-size: 1.6rem; font-weight: 500; }

    .et-scans-header {
        font-size: 0.9rem;
        color: #D1D5DB;
        margin-bottom: 12px;
    }

    .et-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 16px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .et-search-box {
        flex: 1 1 280px;
    }

    .et-search-input {
        width: 100%;
        background: rgba(30, 27, 46, 0.6);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        color: #F3F4F6;
        padding: 12px 14px;
        outline: none;
    }

    .et-search-input:focus {
        border-color: rgba(139, 92, 246, 0.4);
    }

    .et-sort-controls {
        display: flex;
        gap: 12px;
        align-items: end;
        flex-wrap: wrap;
    }

    .et-sort-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .et-sort-label {
        color: #9CA3AF;
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .et-sort-select {
        min-width: 180px;
        background: rgba(30, 27, 46, 0.6);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        color: #F3F4F6;
        padding: 12px 14px;
        outline: none;
    }

    .et-no-results {
        color: #9CA3AF;
        padding: 24px;
        text-align: center;
        border: 1px dashed rgba(255,255,255,0.1);
        border-radius: 12px;
        display: none;
    }

    .et-scan-item {
        background: rgba(30, 27, 46, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 12px;
        display: flex;
        flex-direction: column;
        align-items: stretch;
    }
    .et-scan-left { display: flex; align-items: center; gap: 16px; flex: 1; }
    .et-scan-icon {
        width: 40px; height: 40px; border-radius: 50%; background: #fff;
        display: flex; align-items: center; justify-content: center; color: #8B5CF6; font-size: 1.2rem;
    }
    .et-scan-info { display: flex; flex-direction: column; }
    .et-scan-name { color: #F3F4F6; font-weight: 600; font-size: 0.95rem; }
    .et-scan-date { color: #6B7280; font-size: 0.8rem; }
    
    .et-scan-right { display: flex; align-items: center; gap: 16px; }
    .et-scan-amount { color: #D1D5DB; font-weight: 500; }
    .et-scan-badge {
        background: rgba(239, 68, 68, 0.1);
        color: #EF4444;
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    /* Mobile Responsive Overrides */
    @media (max-width: 768px) {
        .twin-header {
            text-align: center;
        }
        .twin-title {
            font-size: 1.5rem;
        }
        .twin-tabs {
            flex-wrap: wrap;
            justify-content: center;
        }
        .fh-layout {
            flex-direction: column;
        }
        .fh-sidebar {
            width: 100%;
        }
        .fh-main {
            min-width: auto;
            width: 100%;
        }
        .ms-layout {
            flex-direction: column;
            height: auto;
        }
        .ms-assets {
            width: 100%;
            height: 250px;
            max-height: 30vh;
        }
        .ms-chart {
            width: 100%;
            height: 400px;
            min-height: 40vh;
            padding: 8px;
        }
        #lightweight-chart {
            min-height: 300px;
        }
        .ms-trade {
            width: 100%;
        }
        .et-top-boxes {
            flex-direction: column;
        }
        .et-scan-item > div {
            flex-direction: column;
            align-items: flex-start !important;
            gap: 12px;
        }
        .et-scan-right {
            align-self: stretch;
            justify-content: flex-end;
            margin-top: 10px;
        }
        .et-scans-header {
            flex-direction: column;
            align-items: stretch !important;
            gap: 12px;
        }
        .chart-container {
            height: 250px;
        }
    }

</style>
{% endblock %}

{% block user_content %}
<div class="twin-header">
    <h1 class="twin-title">Financial Twin & Market Simulation</h1>
    <p class="twin-subtitle">Analyze your financial health and practice trading with AI assistance.</p>
</div>

<div class="twin-tabs">
    <a href="#" class="tab-link active" onclick="switchTab(event, 'tabHealth')">Financial Health</a>
    <a href="#" class="tab-link" onclick="switchTab(event, 'tabMarket')">Market Simulator</a>
    <a href="#" class="tab-link" onclick="switchTab(event, 'tabExpense')">Expense Tracker</a>
</div>

<!-- Financial Health Tab -->
<div id="tabHealth" class="tab-content" style="display: block;">
    <div class="fh-layout">
        <!-- Sidebar -->
        <div class="fh-sidebar">
            <div class="panel">
                <div class="panel-title">What-If Scenarios</div>
                <div class="scenario-group">
                    <label class="scenario-label">Monthly Income (TND)</label>
                    <input type="range" class="scenario-slider" id="incomeSlider" min="0" max="10000" step="50" value="{{ income }}">
                    <input type="number" class="scenario-input" id="incomeInput" value="{{ income }}">
                </div>
                <div class="scenario-group">
                    <label class="scenario-label">Monthly Expenses (TND)</label>
                    <input type="range" class="scenario-slider" id="expenseSlider" min="0" max="10000" step="50" value="{{ expenses }}">
                    <input type="number" class="scenario-input" id="expenseInput" value="{{ expenses }}">
                </div>
                <div class="scenario-group">
                    <label class="scenario-label">Savings Goal (TND)</label>
                    <input type="number" class="scenario-input" id="goalInput" value="{{ goal }}">
                </div>
                <button class="btn-run" onclick="runSimulation()">Run Simulation</button>
                <button class="btn-reset" onclick="resetScenarios()">Reset to Profile</button>
            </div>

            <div class="panel">
                <div class="panel-title" style="text-align: center;">Financial Health Score</div>
                <div class="health-score-container">
                    <div class="gauge red" id="healthGauge">
                        <span id="healthScore">20%</span>
                    </div>
                    <div class="health-status status-red" id="healthStatusText">High Risk</div>
                </div>
            </div>
        </div>

        <!-- Main -->
        <div class="fh-main">
            <div class="panel">
                <div class="panel-title" style="font-size: 0.9rem; font-weight: normal; color: #D1D5DB; margin-bottom: 8px;">12-Month Projection</div>
                <div style="font-size: 0.75rem; transform: rotate(-90deg); transform-origin: left top; position: absolute; margin-top: 150px; color: #9CA3AF;">Projected Savings (TND)</div>
                <div class="chart-container" id="projectionChartContainer">
                    <canvas id="projectionChart"></canvas>
                </div>
                <div style="text-align: center; color: #9CA3AF; font-size: 0.8rem; margin-top: -10px;">Month</div>
            </div>

            <div class="panel">
                <div class="panel-title">Twin Feedback</div>
                <div class="feedback-box" id="twinFeedback">
                    **Financial Twin Analysis**<br><br>
                    **Good Savings Habit**: You are saving <span id="savePercent">20.0</span>% of your income. Keep it up!<br><br>
                    **Goal Within Reach**: You can reach your savings goal in approx. <span id="goalMonths">34</span> months.<br><br>
                    **Tip**: Your recurring expenses are quite high (<span id="expensePercent">80</span>%). Review your subscriptions and rent/utilities to find potential savings.
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Market Simulator Tab -->
<div id="tabMarket" class="tab-content" style="display: none;">
    <!-- Intelligent Alerts Panel -->
    {% if marketAlerts|length > 0 %}
    <div style="display: flex; gap: 15px; margin-bottom: 20px; overflow-x: auto; padding-bottom: 5px;">
        {% for alert in marketAlerts %}
            {% set bgColor = alert.type == 'BUY' ? 'rgba(16, 185, 129, 0.1)' : (alert.type == 'SELL' ? 'rgba(239, 68, 68, 0.1)' : 'rgba(156, 163, 175, 0.1)') %}
            {% set brColor = alert.type == 'BUY' ? 'rgba(16, 185, 129, 0.3)' : (alert.type == 'SELL' ? 'rgba(239, 68, 68, 0.3)' : 'rgba(156, 163, 175, 0.3)') %}
            {% set txtColor = alert.type == 'BUY' ? '#10B981' : (alert.type == 'SELL' ? '#EF4444' : '#9CA3AF') %}
            
            <div style="min-width: 300px; max-width: 300px; background: {{ bgColor }}; border: 1px solid {{ brColor }}; border-radius: 8px; padding: 12px; display: flex; flex-direction: column; gap: 10px;">
                <div style="display:flex; justify-content: space-between; align-items: top;">
                   <div>
                       <div style="font-weight: 600; color: #F3F4F6;">{{ alert.name }} ({{ alert.symbol }})</div>
                       <div style="font-size: 0.75rem; color: #9CA3AF; margin-top: 2px;">{{ alert.description }}</div>
                   </div>
                   <div style="font-weight: bold; color: {{ txtColor }}; font-size: 0.7rem; padding: 3px 8px; border-radius: 4px; background: rgba(0,0,0,0.2);">{{ alert.type }} SIGNAL</div>
                </div>
                
                <div style="font-size: 0.85rem; color: #D1D5DB; line-height: 1.4; flex-grow: 1;">
                    {{ alert.recommendation }} <span style="color: {{ txtColor }};">({{ alert.change }}% in 24h)</span>
                </div>
                
                <button onclick="selectAsset('{{ alert.id }}', '{{ alert.name }}', '{{ alert.symbol }}', '{{ alert.price }}', '{{ alert.change }}')" style="background: transparent; color: {{ txtColor }}; border: 1px solid {{ brColor }}; border-radius: 6px; padding: 6px 12px; font-weight: 600; font-size: 0.8rem; cursor: pointer; align-self: flex-start; transition: all 0.2s;" onmouseover="this.style.background='{{ bgColor }}'" onmouseout="this.style.background='transparent'">
                    <i class="fas fa-bolt"></i> Trader {{ alert.symbol }}
                </button>
            </div>
        {% endfor %}
    </div>
    {% endif %}

    <div class="ms-layout">
        <!-- Assets List -->
        <div class="panel ms-assets" style="padding: 12px;">
            <div style="color: #9CA3AF; font-size: 0.8rem; margin-bottom: 10px; padding: 0 8px;">Assets</div>
            
            {% for asset in marketAssets %}
                <div class="asset-item {% if loop.first %}active{% endif %}" onclick="selectAsset('{{ asset.id }}', '{{ asset.name }}', '{{ asset.symbol }}', '{{ asset.price }}', '{{ asset.change }}')">
                    <div class="asset-icon"><img src="https://assets.coincap.io/assets/icons/{{ asset.symbol|lower }}@2x.png" alt="{{ asset.symbol }}" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 24 24\' fill=\'%238B5CF6\'><circle cx=\'12\' cy=\'12\' r=\'10\'/></svg>'"></div>
                    <div class="asset-name">{{ asset.name }}</div>
                </div>
            {% endfor %}

            <button style="background: transparent; color: #9CA3AF; border: none; padding: 10px; text-align: left; font-size: 0.8rem; margin-top: auto; cursor: pointer;">Refresh</button>
        </div>

        <!-- Chart -->
        <div class="panel ms-chart" style="padding: 16px;">
            <div class="ms-chart-header">
                <div class="chart-symbol" id="chartSymbol">bitcoin</div>
                <div style="color: #9CA3AF;">|</div>
                <div class="chart-price" id="chartPrice">196337.36 TND <span style="font-size: 0.7rem;">USD</span></div>
                <div class="chart-change change-down" id="chartChange">-0.26%</div>
            </div>
            <div class="ai-badge">AI: HOLD</div>
            <div id="lightweight-chart"></div>
        </div>

        <!-- Trade -->
        <div class="panel ms-trade">
            <div style="color: #D1D5DB; font-size: 0.9rem; font-weight: 500; margin-bottom: 12px;">Trade</div>
            
            <div style="color: #9CA3AF; font-size: 0.8rem;">Amount</div>
            <div class="trade-field">
                <input type="number" value="0.0" step="0.1" min="0" id="tradeAmount" oninput="updateTradeEst()">
                <span>UNITS</span>
            </div>
            
            <div class="trade-info-row">
                <span>Max Buy:</span>
                <span class="trade-info-val" id="tradeAvailBuy">0.000000 Units</span>
            </div>
            <div class="trade-info-row">
                <span>Est. Cost:</span>
                <span class="trade-info-val" id="tradeEst">0.00 TND</span>
            </div>

            <div style="margin-top: 16px; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 16px;">
                <div style="color: #9CA3AF; font-size: 0.8rem; margin-bottom: 8px;">Position</div>
                <div class="trade-info-row">
                    <span>Owned:</span>
                    <span class="trade-info-val" id="posOwned">0</span>
                </div>
                <div class="trade-info-row">
                    <span>Avg Cost:</span>
                    <span class="trade-info-val" id="posAvg">0.00 USD</span>
                </div>
            </div>

            <div class="wallet-box">
                <div class="wallet-box-title">Wallet</div>
                <div class="wallet-box-val" id="walletBalanceDisplay">{{ walletBalance|number_format(2, '.', '') }} TND</div>
            </div>

            <div style="display: flex; gap: 10px; margin-top: 16px;">
                <button id="btnBuyAction" class="btn-trade buy" style="flex: 1; padding: 12px; font-size: 1rem;" onclick="executeTrade('buy', this)">BUY</button>
                <button id="btnSellAction" class="btn-trade sell" style="flex: 1; padding: 12px; font-size: 1rem;" onclick="executeTrade('sell', this)">SELL</button>
            </div>
        </div>
    </div>
</div>

<!-- Expense Tracker Tab -->
<div id="tabExpense" class="tab-content" style="display: none;">
    <div class="et-top-boxes">
        <div class="et-box">
