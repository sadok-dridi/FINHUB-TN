            </div>
        {{ form_end(escrowForm) }}
    </div>
</div>

<!-- Escrow Details Modal -->
<div id="escrowDetailsModal" class="modal-overlay">
    <div class="modal-content" onclick="event.stopPropagation()">
        <button class="modal-close" onclick="closeModals()">&times;</button>
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <h3 id="edTitle" style="color: #E9D5FF; font-size: 1.4rem; font-weight: 600; margin: 0;">Escrow #--</h3>
            <span id="edStatusBadge" style="font-size: 0.8rem; padding: 6px 14px; border-radius: 12px; font-weight: bold; background: #fff7ed; color: #c2410c; text-transform: uppercase;">LOCKED</span>
        </div>

        <div style="text-align: center; margin-bottom: 24px;">
            <div style="color: #9CA3AF; font-size: 0.9rem; margin-bottom: 8px;">Locked Amount</div>
