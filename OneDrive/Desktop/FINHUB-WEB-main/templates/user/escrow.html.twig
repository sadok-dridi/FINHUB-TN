{% extends 'user/layout.html.twig' %}

{% block title %}Escrow & Trust - FinHub{% endblock %}

{% block user_stylesheets %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    /* Headers & Layout */
    .escrow-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 20px;
    }
    
    .escrow-title-container {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    
    .escrow-title {
        font-size: 1.8rem;
        font-weight: 600;
        color: #F3F4F6;
        margin: 0;
        letter-spacing: -0.5px;
    }
    
    .escrow-subtitle {
        font-size: 0.95rem;
        color: #9CA3AF;
        margin: 0;
    }

    .escrow-actions-group {
        display: flex;
        align-items: center;
        gap: 24px;
        flex-wrap: wrap;
    }

    /* Trust Score Badge */
    .trust-score-badge {
        background: rgba(20, 18, 35, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 10px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    }

    .trust-score-info {
        display: flex;
        flex-direction: column;
    }

    .trust-score-label {
        font-size: 0.75rem;
        color: #6B7280;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .trust-score-value {
        font-size: 1.4rem;
        font-weight: 700;
        color: #A78BFA;
        margin: 0;
        line-height: 1;
    }

    /* SVG Circular Progress */
    .circular-progress {
        position: relative;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .circular-progress svg {
        transform: rotate(-90deg);
        width: 100%;
        height: 100%;
    }

    .circular-progress circle {
        fill: none;
        stroke-width: 3;
        stroke-linecap: round;
    }

    .circular-progress circle.bg {
        stroke: rgba(255, 255, 255, 0.1);
    }

    .circular-progress circle.progress {
        stroke: #10B981; /* Default to Green for good trust */
        stroke-dasharray: 100;
        stroke-dashoffset: 20; /* Example default */
        transition: stroke-dashoffset 1s ease;
    }

    .circular-progress .icon {
        position: absolute;
        color: #10B981;
        font-size: 0.9rem;
    }

    /* Buttons */
    .escrow-buttons {
        display: flex;
        gap: 12px;
    }

    .btn-add-contact {
        background: linear-gradient(135deg, #EC4899, #D946EF);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 10px 18px;
        font-weight: 500;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 4px 15px rgba(236, 72, 153, 0.3);
    }
    .btn-add-contact:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(236, 72, 153, 0.4);
    }

    .btn-new-escrow {
        background: linear-gradient(135deg, #A855F7, #8B5CF6);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 10px 18px;
        font-weight: 500;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 4px 15px rgba(168, 85, 247, 0.3);
    }
    .btn-new-escrow:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(168, 85, 247, 0.4);
    }

    /* Tabs */
    .escrow-tabs {
        display: flex;
        gap: 24px;
        margin-bottom: 30px;
        align-items: center;
    }

    .tab-link {
        color: #9CA3AF;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        padding: 8px 16px;
        border-radius: 20px;
        transition: all 0.2s ease;
    }

    .tab-link:hover {
        color: #E5E7EB;
    }

    .tab-link.active {
        color: #fff;
        background: #8B5CF6;
        box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);
    }

    .tab-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 16px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .tab-search-form {
        flex: 1 1 280px;
    }

    .tab-search-input {
        width: 100%;
        background: rgba(20, 18, 35, 0.6);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        padding: 12px 16px;
        color: #F3F4F6;
        outline: none;
    }

    .tab-search-input:focus {
        border-color: rgba(139, 92, 246, 0.35);
    }

    .tab-sort-form {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: end;
    }

    .tab-sort-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .tab-sort-label {
        color: #9CA3AF;
        font-size: 0.78rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .tab-sort-select {
        min-width: 180px;
        background: rgba(20, 18, 35, 0.6);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px;
        padding: 12px 14px;
        color: #F3F4F6;
        outline: none;
    }

    .tab-sort-select:focus {
        border-color: rgba(139, 92, 246, 0.35);
    }

    /* Trusted Contact Cards Grid */
    .trusted-contacts-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
    }

    .trusted-card {
        background: rgba(20, 18, 35, 0.6);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 20px;
        min-width: 320px;
        max-width: 360px;
        flex: 1;
        display: flex;
        align-items: center;
        gap: 20px;
        transition: all 0.3s ease;
    }

    .trusted-card:hover {
        background: rgba(255, 255, 255, 0.03);
        transform: translateY(-2px);
        border-color: rgba(255, 255, 255, 0.08);
    }

    /* Contact Card Avatar Side */
    .trusted-card-left {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        width: 80px;
    }

    .trusted-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border: 2px solid #A855F7; /* Purple accent ring */
        background: rgba(168, 85, 247, 0.1);
        padding: 2px;
    }

    .trusted-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
    }

    .trusted-initial {
        color: #E9D5FF;
        font-weight: 600;
        font-size: 1.3rem;
        letter-spacing: 1px;
    }

    .trusted-name {
        color: #F3F4F6;
        font-weight: 500;
        font-size: 0.95rem;
        text-align: center;
        word-break: break-all;
    }

    /* Contact Card Details Side */
    .trusted-card-right {
        display: flex;
        flex-direction: column;
        gap: 10px;
        flex: 1;
        border-left: 1px solid rgba(255, 255, 255, 0.05);
        padding-left: 20px;
    }

    .detail-row {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #9CA3AF;
        font-size: 0.85rem;
    }

    .detail-row i {
        color: #8B5CF6;
        width: 14px;
        text-align: center;
    }

    .trust-score-row {
        margin-top: 4px;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .score-green { color: #10B981; }
    .score-yellow { color: #F59E0B; }
    .score-red { color: #EF4444; }

    .trust-score-row i.score-green { color: #10B981; }
    .trust-score-row i.score-yellow { color: #F59E0B; }
    .trust-score-row i.score-red { color: #EF4444; }

    /* ─── CONTACT DETAILS VIEW ─── */
    #escrowMainView {
        transition: opacity 0.3s ease;
    }
    
    #contactDetailsView {
        display: none;
        animation: fadeIn 0.3s ease;
    }
    
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

    .back-btn {
        background: transparent;
        border: none;
        color: #D1D5DB;
        font-size: 1.1rem;
        font-weight: 500;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 24px;
        transition: color 0.2s ease;
        padding: 0;
    }
    .back-btn:hover { color: #fff; }

    .contact-details-layout {
        display: flex;
        gap: 30px;
        align-items: flex-start;
        flex-wrap: wrap;
    }

    .contact-sidebar {
        background: rgba(20, 18, 35, 0.6);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 20px;
        width: 380px;
        padding: 30px;
        display: flex;
        flex-direction: column;
    }

    .sidebar-avatar-large {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        margin: 0 auto 16px;
        border: 3px solid #8B5CF6;
        padding: 3px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(139, 92, 246, 0.1);
        overflow: hidden;
    }
    .sidebar-avatar-large img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
    .sidebar-avatar-large .initial { color: #E9D5FF; font-size: 2.2rem; font-weight: 600; }

    .sidebar-name {
        text-align: center;
        color: #fff;
        font-size: 1.4rem;
        font-weight: 600;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    .sidebar-name i { font-size: 0.9rem; color: #8B5CF6; cursor: pointer; }

    .sidebar-info-box {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 24px;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    
    .sidebar-info-row {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .sidebar-info-icon {
        width: 32px; height: 32px;
        background: rgba(139, 92, 246, 0.1);
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        color: #A855F7;
        flex-shrink: 0;
    }
    .sidebar-info-text { display: flex; flex-direction: column; }
    .sidebar-info-text small { color: #6B7280; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; }
    .sidebar-info-text span { color: #D1D5DB; font-size: 0.9rem; word-break: break-all; }
    .sidebar-inline-edit { color: #8B5CF6; cursor: pointer; font-size: 0.85rem; }

    .sidebar-metrics {
        display: flex;
        gap: 12px;
        margin-bottom: 30px;
    }
    .metric-box {
        flex: 1;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    .metric-box small { color: #9CA3AF; font-size: 0.75rem; display: flex; align-items: center; gap: 6px; }
    .metric-box span { font-size: 1.4rem; font-weight: 700; }

    .btn-block-purple {
        background: linear-gradient(135deg, #A855F7, #D946EF);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 14px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        width: 100%;
        margin-bottom: 12px;
        transition: opacity 0.2s;
    }
    .btn-block-purple:hover { opacity: 0.9; }

    .btn-block-red-outline {
        background: transparent;
        color: #EF4444;
        border: 1px solid rgba(239, 68, 68, 0.3);
        border-radius: 10px;
        padding: 14px;
        font-weight: 500;
        font-size: 1rem;
        cursor: pointer;
        width: 100%;
        display: flex; align-items: center; justify-content: center; gap: 8px;
        transition: all 0.2s;
    }
    .btn-block-red-outline:hover { background: rgba(239, 68, 68, 0.1); }

    .contact-main {
        flex: 1;
        min-width: 300px;
    }
    
    .contact-main-title {
        color: #E5E7EB;
        font-size: 1.1rem;
        font-weight: 500;
        margin-bottom: 20px;
    }

    .activity-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    
    .activity-item {
        background: rgba(20, 18, 35, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        padding: 16px;
        display: flex;
        align-items: center;
        gap: 16px;
        transition: background 0.2s;
    }
    .activity-item:hover { background: rgba(255, 255, 255, 0.05); }

    .activity-icon {
        width: 40px; height: 40px;
        border-radius: 50%;
        background: white;
        display: flex; align-items: center; justify-content: center;
        color: #8B5CF6;
        font-size: 1.2rem;
        flex-shrink: 0;
    }
    
    .activity-info { display: flex; flex-direction: column; }
    .activity-info strong { color: #fff; font-size: 0.95rem; }
    .activity-info span { color: #9CA3AF; font-size: 0.8rem; }

    /* ─── CREATE ESCROW MODAL ─── */
    .modal-overlay {
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(5px);
        display: flex; align-items: center; justify-content: center;
        z-index: 1000; opacity: 0; visibility: hidden; transition: all 0.3s ease;
    }
    .modal-overlay.active { opacity: 1; visibility: visible; }
    .modal-content {
        background: #151120; border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px; padding: 30px; width: 90%; max-width: 500px;
        position: relative; transform: translateY(20px); transition: transform 0.3s ease;
        max-height: 90vh; overflow-y: auto;
    }
    .modal-overlay.active .modal-content { transform: translateY(0); }
    
    .modal-close {
        position: absolute;
        top: 20px;
        right: 20px;
        background: transparent;
        border: none;
        color: #9CA3AF;
        font-size: 1.5rem;
        cursor: pointer;
        transition: color 0.2s;
        padding: 0;
        line-height: 1;
        width: auto;
        height: auto;
    }
    .modal-close:hover {
        color: #fff;
    }

    .modal-header-escrow { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .modal-header-icon { width: 44px; height: 44px; border-radius: 50%; background: rgba(139,92,246,0.15); display: flex; align-items: center; justify-content: center; color: #A855F7; font-size: 1.2rem; }
    .modal-header-escrow h3 { color: #E9D5FF; font-size: 1.3rem; font-weight: 600; margin: 0 0 4px 0; }
    .modal-header-escrow p { color: #9CA3AF; font-size: 0.85rem; margin: 0; }
    
    .form-group { margin-bottom: 16px; }
    .form-label { display: block; color: #D1D5DB; margin-bottom: 8px; font-size: 0.9rem; }
    .form-input, .form-select, .form-textarea {
        width: 100%; background: rgba(30, 27, 46, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 10px;
        padding: 12px 14px; color: #fff; font-size: 0.95rem; outline: none; transition: border-color 0.2s;
    }
    .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: #8B5CF6; }
    .form-textarea { resize: vertical; min-height: 80px; }
    
    .form-row { display: flex; gap: 16px; margin-bottom: 16px; }
    .form-row .form-group { flex: 1; margin-bottom: 0; }

    .checkbox-group { display: flex; align-items: center; gap: 10px; margin-top: 10px; }
    .checkbox-group input[type="checkbox"] { width: 16px; height: 16px; accent-color: #8B5CF6; cursor: pointer; }
    .checkbox-group label { color: #9CA3AF; font-size: 0.85rem; cursor: pointer; }

    .escrow-fee-box {
        background: rgba(30, 27, 46, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 10px;
        padding: 16px;
        margin-bottom: 24px;
        display: flex; flex-direction: column; gap: 10px;
    }
    .fee-row { display: flex; justify-content: space-between; color: #9CA3AF; font-size: 0.9rem; }
    .fee-row.total { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 10px; color: #fff; font-weight: 600; margin-top: 4px; }
    .fee-row.total span:last-child { color: #A855F7; }

    .modal-actions { display: flex; justify-content: flex-end; gap: 12px; }
    .btn-cancel { background: transparent; color: #D1D5DB; border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 8px; padding: 10px 20px; cursor: pointer; transition: all 0.2s; }
    .btn-cancel:hover { background: rgba(255, 255, 255, 0.05); color: #fff; }
    .btn-submit { background: linear-gradient(135deg, #A855F7, #D946EF); color: #fff; border: none; border-radius: 8px; padding: 10px 20px; font-weight: 600; cursor: pointer; transition: opacity 0.2s; }
    .btn-submit:hover { opacity: 0.9; }

    /* --- Mobile Responsiveness --- */
    @media (max-width: 768px) {
        .escrow-header {
            flex-direction: column;
            align-items: stretch;
            gap: 16px;
        }
        .escrow-actions-group {
            flex-direction: column;
            align-items: stretch;
            gap: 16px;
        }
        .escrow-buttons {
            width: 100%;
            display: flex;
        }
        .escrow-buttons button {
            flex: 1;
            justify-content: center;
        }
        .trust-score-badge {
            justify-content: space-between;
        }
        
        /* Tabs horizontal scrolling */
        .escrow-tabs {
            gap: 12px;
            overflow-x: auto;
            padding-bottom: 8px;
            /* Hide scrollbar */
            scrollbar-width: none; 
            -ms-overflow-style: none;
            -webkit-overflow-scrolling: touch;
        }
        .escrow-tabs::-webkit-scrollbar {
            display: none;
        }
        .tab-link {
            white-space: nowrap;
        }

        /* Card grids & Layouts */
        .trusted-card {
            min-width: 100%;
            max-width: 100%;
            flex-direction: column;
            text-align: center;
            gap: 12px;
        }
        .trusted-card-left {
            width: 100%;
            flex-direction: row;
            justify-content: flex-start;
            gap: 16px;
        }
        .trusted-card-right {
            border-left: none;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            padding-left: 0;
            padding-top: 12px;
            width: 100%;
        }
        
        .contact-sidebar {
            width: 100%;
            padding: 20px;
        }
        
        /* Activity Items stack */
        .activity-item {
            flex-direction: column;
            align-items: stretch !important;
            gap: 12px;
        }
        .activity-item > div:first-child {
            align-items: center;
            width: 100%;
        }
        .activity-item > div:last-child {
            justify-content: space-between;
            width: 100%;
            padding-top: 12px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* Modals & Forms */
        .modal-content {
            padding: 20px;
            width: 95%;
        }
        .form-row {
            flex-direction: column;
            gap: 16px;
        }
        .modal-actions {
            flex-direction: column-reverse;
        }
        .modal-actions button {
            width: 100%;
        }
    }

</style>
{% endblock %}

{% block user_content %}
<div class="wallet-container">

    <!-- Header Section -->
    <div id="escrowMainView">
        <div class="escrow-header">
            <div class="escrow-title-container">
                <h1 class="escrow-title">Escrow & Trust</h1>
                <p class="escrow-subtitle">Secure payments held until you are satisfied.</p>
            </div>

            <div class="escrow-actions-group">
                <!-- Trust Score Badge -->
                <div class="trust-score-badge">
                    <div class="trust-score-info">
                        <span class="trust-score-label">Trust Score</span>
                        <span class="trust-score-value">{{ trustScore }}</span>
                    </div>
                    
                    <div class="circular-progress">
                        {% set dashOffset = 100 - (trustScore > 100 ? 100 : trustScore) %}
                        {% set scoreColor = trustScore >= 70 ? '#10B981' : (trustScore >= 30 ? '#F59E0B' : '#EF4444') %}
                        
                        <svg viewBox="0 0 36 36">
                            <circle class="bg" cx="18" cy="18" r="16"></circle>
                            <circle class="progress" cx="18" cy="18" r="16" style="stroke: {{ scoreColor }}; stroke-dasharray: 100; stroke-dashoffset: {{ dashOffset }};"></circle>
                        </svg>
                        <i class="fas fa-shield-alt icon" style="color: {{ scoreColor }};"></i>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="escrow-buttons">
                    <button class="btn-add-contact" onclick="promptAddContact()"><i class="fas fa-user-plus"></i> Add Contact</button>
                    <button class="btn-new-escrow" onclick="openNewEscrowModal()"><i class="fas fa-plus"></i> New Escrow</button>
                </div>
            </div>
        </div>

        <!-- Tabs Navigation -->
        <div class="escrow-tabs">
            <a href="{{ path('app_user_escrow', app.request.query.all|merge({tab: 'contacts'})) }}" class="tab-link {{ activeTab|default('contacts') == 'contacts' ? 'active' : '' }}">Contacts</a>
            <a href="{{ path('app_user_escrow', app.request.query.all|merge({tab: 'active'})) }}" class="tab-link {{ activeTab|default('contacts') == 'active' ? 'active' : '' }}">Active</a>
            <a href="{{ path('app_user_escrow', app.request.query.all|merge({tab: 'history'})) }}" class="tab-link {{ activeTab|default('contacts') == 'history' ? 'active' : '' }}">History</a>
            <a href="{{ path('app_user_escrow', app.request.query.all|merge({tab: 'disputes'})) }}" class="tab-link {{ activeTab|default('contacts') == 'disputes' ? 'active' : '' }}">Disputes</a>
        </div>

        <div class="tab-toolbar">
            <form method="get" class="tab-search-form">
                <input type="hidden" name="tab" value="{{ activeTab|default('contacts') }}">
                <input type="hidden" name="sort" value="{{ sort|default(activeTab|default('contacts') == 'contacts' ? 'name' : 'created') }}">
                <input type="hidden" name="direction" value="{{ direction|default('desc') }}">
                <input type="text" name="search" value="{{ search|default('') }}" class="tab-search-input" placeholder="{% if activeTab|default('contacts') == 'contacts' %}Search contacts by name, email, phone, or trust score...{% else %}Search escrows by id, amount, status, party, or condition...{% endif %}">
            </form>

            <form method="get" class="tab-sort-form">
                <input type="hidden" name="tab" value="{{ activeTab|default('contacts') }}">
                <input type="hidden" name="search" value="{{ search|default('') }}">
                <div class="tab-sort-group">
                    <label for="escrowSort" class="tab-sort-label">Sort By</label>
                    <select id="escrowSort" name="sort" class="tab-sort-select" onchange="this.form.submit()">
                        {% if activeTab|default('contacts') == 'contacts' %}
                            <option value="name" {{ sort|default('name') == 'name' ? 'selected' : '' }}>Name</option>
                            <option value="email" {{ sort|default('name') == 'email' ? 'selected' : '' }}>Email</option>
                            <option value="trust" {{ sort|default('name') == 'trust' ? 'selected' : '' }}>Trust Score</option>
                        {% else %}
                            <option value="created" {{ sort|default('created') == 'created' ? 'selected' : '' }}>Created</option>
                            <option value="amount" {{ sort|default('created') == 'amount' ? 'selected' : '' }}>Amount</option>
                            <option value="status" {{ sort|default('created') == 'status' ? 'selected' : '' }}>Status</option>
                            <option value="party" {{ sort|default('created') == 'party' ? 'selected' : '' }}>Other Party</option>
                        {% endif %}
                    </select>
                </div>
                <div class="tab-sort-group">
                    <label for="escrowDirection" class="tab-sort-label">Direction</label>
                    <select id="escrowDirection" name="direction" class="tab-sort-select" onchange="this.form.submit()">
                        <option value="desc" {{ direction|default('desc') == 'desc' ? 'selected' : '' }}>Descending</option>
                        <option value="asc" {{ direction|default('desc') == 'asc' ? 'selected' : '' }}>Ascending</option>
                    </select>
                </div>
            </form>
        </div>

        <!-- Trusted Contacts View -->
        <div id="tabContacts" class="tab-content" style="display: {{ activeTab|default('contacts') == 'contacts' ? 'block' : 'none' }};">
            <div class="trusted-contacts-grid">
            {% if contacts is empty %}
                <div style="color: #9CA3AF; padding: 40px; text-align: center; width: 100%; border: 1px dashed rgba(255,255,255,0.1); border-radius: 16px;">
                    <i class="fas fa-user-shield" style="font-size: 3rem; color: #4B5563; margin-bottom: 16px;"></i>
                    <p>No trusted contacts found.</p>
                    <p style="font-size: 0.85rem;">Add a contact to begin secure escrow transactions with them.</p>
                </div>
            {% else %}
                {% for contact in contacts %}
                    <div class="trusted-card" style="cursor: pointer;" onclick="openContactDetails(this)" 
                         data-id="{{ contact.contactUserId }}"
                         data-email="{{ contact.email|escape('html_attr') }}"
                         data-phone="{{ contact.phone|escape('html_attr') }}"
                         data-name="{{ contact.displayName|escape('html_attr') }}"
                         data-initial="{{ contact.initial|escape('html_attr') }}"
                         data-avatar="{{ contact.avatarUrl|default('')|escape('html_attr') }}"
                         data-score="{{ contact.trustScore }}"
                         data-wallet="{{ contact.walletStatus|escape('html_attr') }}"
                         data-history="{{ contact.history|json_encode|escape('html_attr') }}">
                        <!-- Avatar & Name -->
                        <div class="trusted-card-left">
                            <div class="trusted-avatar">
                                {% if contact.avatarUrl %}
                                    <img src="{{ contact.avatarUrl }}" alt="{{ contact.displayName }}">
                                {% else %}
                                    <span class="trusted-initial">{{ contact.initial }}</span>
                                {% endif %}
                            </div>
                            <div class="trusted-name">{{ contact.displayName|lower }}</div>
                        </div>

                        <!-- Details -->
                        <div class="trusted-card-right">
                            <div class="detail-row">
                                <i class="fas fa-envelope"></i>
                                <span style="word-break: break-all;">{{ contact.email }}</span>
                            </div>
                            <div class="detail-row">
                                <i class="fas fa-phone-alt"></i>
                                <span>{{ contact.phone|default('N/A') }}</span>
                            </div>
                            
                            {% set contactScoreColorClass = contact.trustScore >= 70 ? 'score-green' : (contact.trustScore >= 30 ? 'score-yellow' : 'score-red') %}
                            
                            <div class="trust-score-row {{ contactScoreColorClass }}">
                                <i class="fas fa-shield-alt"></i>
                                <span>Trust Score: {{ contact.trustScore }}</span>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}
            </div>
        </div>

        <!-- Active Escrows View -->
        <div id="tabActive" class="tab-content" style="display: {{ activeTab|default('contacts') == 'active' ? 'block' : 'none' }};">
            <div class="activity-list">
                {% if activeEscrows is empty %}
                    <div style="color: #9CA3AF; padding: 40px; text-align: center; width: 100%; border: 1px dashed rgba(255,255,255,0.1); border-radius: 16px;">
                        <i class="fas fa-box-open" style="font-size: 3rem; color: #4B5563; margin-bottom: 16px;"></i>
                        <p>No active escrows found.</p>
                    </div>
                {% else %}
                    {% for escrow in activeEscrows %}
                        <div class="activity-item" style="justify-content: space-between;">
                            <div style="display: flex; align-items: center; gap: 16px;">
                                <div class="activity-icon"><i class="fas fa-expand"></i></div>
                                <div class="activity-info">
                                    <strong style="font-size: 1.1rem;">Escrow #{{ escrow.id }}</strong>
                                    <span>{{ escrow.condition }}</span>
                                </div>
                            </div>
                            
                            <div style="display: flex; align-items: center; gap: 16px;">
                                <div style="font-weight: 500; color: #fff; font-size: 1.1rem;">{{ escrow.amount }} TND</div>
                                {% set statusBadgeStyle = escrow.status == 'LOCKED' ? 'background: #fff7ed; color: #c2410c;' : 'background: #fef2f2; color: #b91c1c;' %}
                                <span style="font-size: 0.75rem; padding: 6px 14px; border-radius: 20px; font-weight: 700; {{ statusBadgeStyle }}">{{ escrow.status }}</span>
                                <button class="btn-cancel" style="padding: 8px 16px; font-size: 0.85rem; border-color: rgba(255,255,255,0.1);" 
                                    onclick='openEscrowDetail({{ escrow|json_encode|raw }})'>View</button>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        <!-- History Escrows View -->
        <div id="tabHistory" class="tab-content" style="display: {{ activeTab|default('contacts') == 'history' ? 'block' : 'none' }};">
            <div class="activity-list">
                {% if historyEscrows is empty %}
                    <div style="color: #9CA3AF; padding: 40px; text-align: center; width: 100%; border: 1px dashed rgba(255,255,255,0.1); border-radius: 16px;">
                        <i class="fas fa-history" style="font-size: 3rem; color: #4B5563; margin-bottom: 16px;"></i>
                        <p>No escrow history found.</p>
                    </div>
                {% else %}
                    {% for escrow in historyEscrows %}
                        <div class="activity-item" style="justify-content: space-between;">
                            <div style="display: flex; align-items: center; gap: 16px;">
                                <div class="activity-icon"><i class="fas fa-expand"></i></div>
                                <div class="activity-info">
                                    <strong style="font-size: 1.1rem;">Escrow #{{ escrow.id }}</strong>
                                    <span>{{ escrow.condition }}</span>
                                </div>
                            </div>
                            
                            <div style="display: flex; align-items: center; gap: 16px;">
                                <div style="font-weight: 500; color: #fff; font-size: 1.1rem;">{{ escrow.amount }} TND</div>
                                {% set statusBadgeStyle = escrow.status == 'RELEASED' ? 'background: #dcfce7; color: #047857;' : 'background: #f3f4f6; color: #4b5563;' %}
                                <span style="font-size: 0.75rem; padding: 6px 14px; border-radius: 20px; font-weight: 700; {{ statusBadgeStyle }}">{{ escrow.status }}</span>
                                {% if escrow.status in ['RELEASED', 'REFUNDED'] %}
                                    <button class="btn-block-red-outline" style="margin: 0; padding: 8px 12px; font-size: 0.85rem;" onclick="deleteEscrowItem({{ escrow.id }}, '{{ escrow.status|e('js') }}')" title="Delete {{ escrow.status|lower }} escrow">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                {% endif %}
                                <button class="btn-cancel" style="padding: 8px 16px; font-size: 0.85rem; border-color: rgba(255,255,255,0.1);" 
                                    onclick='openEscrowDetail({{ escrow|json_encode|raw }})'>View</button>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        <!-- Disputed Escrows View -->
        <div id="tabDisputes" class="tab-content" style="display: {{ activeTab|default('contacts') == 'disputes' ? 'block' : 'none' }};">
            <div class="activity-list">
                {% if disputedEscrows is empty %}
                    <div style="color: #9CA3AF; padding: 40px; text-align: center; width: 100%; border: 1px dashed rgba(255,255,255,0.1); border-radius: 16px;">
                        <i class="fas fa-gavel" style="font-size: 3rem; color: #4B5563; margin-bottom: 16px;"></i>
                        <p>No disputed escrows found.</p>
                    </div>
                {% else %}
                    {% for escrow in disputedEscrows %}
                        <div class="activity-item" style="justify-content: space-between;">
                            <div style="display: flex; align-items: center; gap: 16px;">
                                <div class="activity-icon"><i class="fas fa-expand"></i></div>
                                <div class="activity-info">
                                    <strong style="font-size: 1.1rem;">Escrow #{{ escrow.id }}</strong>
                                    <span>{{ escrow.condition }}</span>
                                </div>
                            </div>
                            
                            <div style="display: flex; align-items: center; gap: 16px;">
                                <div style="font-weight: 500; color: #fff; font-size: 1.1rem;">{{ escrow.amount }} TND</div>
                                <span style="font-size: 0.75rem; padding: 6px 14px; border-radius: 20px; font-weight: 700; background: #fef2f2; color: #b91c1c;">{{ escrow.status }}</span>
                                <button class="btn-cancel" style="padding: 8px 16px; font-size: 0.85rem; border-color: rgba(255,255,255,0.1);" 
                                    onclick='openEscrowDetail({{ escrow|json_encode|raw }})'>View</button>
                            </div>
                        </div>
                    {% endfor %}
