                    <div class="fee-row">
                        <span>Subtotal</span>
                        <span id="feeSubtotal">0.000 TND</span>
                    </div>
                    <div class="fee-row">
                        <span>Escrow Fee (1%)</span>
                        <span id="feeAmount">0.000 TND (Paid by Seller)</span>
                    </div>
                    <div class="fee-row total">
                        <span>Total to Pay</span>
                        <span id="feeTotal">0.000 TND</span>
                    </div>
