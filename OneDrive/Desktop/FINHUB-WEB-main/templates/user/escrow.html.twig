<!-- Create Secure Escrow Modal -->
<div id="newEscrowModal" class="modal-overlay">
    <div class="modal-content" onclick="event.stopPropagation()">
        <button class="modal-close" onclick="closeModals()">&times;</button>
        
        <div class="modal-header-escrow">
            <div class="modal-header-icon"><i class="fas fa-shield-alt"></i></div>
            <div>
                <h3>Create Secure Escrow</h3>
                <p>Hold funds securely until conditions are met.</p>
            </div>
        </div>

        {{ form_start(escrowForm, {'attr': {'id': 'newEscrowForm', 'novalidate': 'novalidate', 'onsubmit': 'submitNewEscrow(event)'}}) }}
            <div class="form-group">
                <label class="form-label" for="{{ escrowForm.email.vars.id }}">{{ form_label(escrowForm.email) }}</label>
                {{ form_widget(escrowForm.email, {'attr': {'class': 'form-input', 'placeholder': "Enter seller's email"}}) }}
