            <div style="color: #E5E7EB; font-weight: 500; margin-bottom: 16px;">Scan to Release</div>
            
            <div id="edQrCodeContainer" style="background: white; padding: 10px; display: inline-block; border-radius: 8px; margin-bottom: 16px;">
                <img id="edQrCode" src="" alt="QR Code" style="width: 150px; height: 150px; display: block;">
            </div>
            
            <div id="edSecretCode" style="color: #A78BFA; font-family: monospace; font-size: 1.1rem; letter-spacing: 1px; margin-bottom: 12px;">Secret Code: --</div>
