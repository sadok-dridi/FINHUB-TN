            <button id="edRefundBtn" onclick="handleSenderRefund()" style="display:none; background: #3B82F6; color: white; border: none; border-radius: 8px; padding: 12px 24px; font-weight: 600; cursor: pointer; width: 100%; margin-top:10px; transition: opacity 0.2s;">Claim Refund (Expired)</button>
        </div>

        <!-- Receiver View (Input Code) -->
        <div id="edReceiverView" style="display: none; background: rgba(20, 18, 35, 0.6); border: 1px solid rgba(255,255,255,0.05); border-radius: 16px; padding: 24px; text-align: center; margin-bottom: 24px;">
            <div style="color: #E5E7EB; font-weight: 500; margin-bottom: 16px;">Claim Escrow Funds</div>
            <p style="color: #9CA3AF; font-size: 0.85rem; margin-bottom: 16px;">Enter the secret code provided by the sender or scan their QR code to claim the funds.</p>
            
            <input type="text" id="edCodeInput" class="form-input" placeholder="Enter Secret Code" style="text-align: center; font-family: monospace; font-size: 1.2rem; letter-spacing: 2px; margin-bottom: 16px;">
            
            <button onclick="handleReceiverClaim()" style="background: #10B981; color: white; border: none; border-radius: 8px; padding: 12px 24px; font-weight: 600; cursor: pointer; width: 100%; transition: opacity 0.2s;">Claim Funds</button>
        </div>

        <div style="display: flex; justify-content: space-between; gap: 16px;">
            <button class="btn-cancel" style="flex: 1;" onclick="closeModals()">Close</button>
            <button id="edDisputeBtn" onclick="handleDispute()" class="btn-block-red-outline" style="flex: 1; margin: 0; padding: 10px 20px;">Dispute Transaction</button>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    let currentContactId = null;
    let currentContactName = '';
    let currentContactPhone = '';

    // Contact Details Navigation Logic
    function openContactDetails(cardElement) {
        // Extract data
        currentContactId = cardElement.dataset.id;
        const name = cardElement.dataset.name;
        currentContactName = name;
        const email = cardElement.dataset.email;
        const phone = cardElement.dataset.phone;
        currentContactPhone = phone && phone !== 'N/A' ? phone : '';
        const score = parseInt(cardElement.dataset.score);
        const wallet = cardElement.dataset.wallet;
        const initial = cardElement.dataset.initial;
        const avatar = cardElement.dataset.avatar;
        const historyJson = cardElement.dataset.history;
        
        let history = [];
        try { history = JSON.parse(historyJson); } catch(e) {}

        // Populate Left Sidebar
        document.getElementById('cdName').innerHTML = `${name} <i class="fas fa-pen" onclick="editContactAlias(event)"></i>`;
        document.getElementById('cdEmail').innerText = email;
        document.getElementById('cdPhone').innerText = phone || 'N/A';
        
        const scoreEl = document.getElementById('cdScore');
        scoreEl.innerText = score;
        if(score >= 70) scoreEl.style.color = '#10B981';
        else if(score >= 30) scoreEl.style.color = '#F59E0B';
        else scoreEl.style.color = '#EF4444';

        const walletEl = document.getElementById('cdWallet');
        walletEl.innerText = wallet;
        walletEl.style.color = wallet === 'ACTIVE' ? '#10B981' : '#EF4444';

        // Avatar logic
        const cdAvatar = document.getElementById('cdAvatar');
        const cdInitial = document.getElementById('cdInitial');
        if (avatar) {
            cdAvatar.src = avatar;
            cdAvatar.style.display = 'block';
            cdInitial.style.display = 'none';
        } else {
            cdAvatar.style.display = 'none';
            cdInitial.innerText = initial;
            cdInitial.style.display = 'block';
        }

        // Populate Activity List
        const listEl = document.getElementById('cdActivityList');
        listEl.innerHTML = '';
        if (history.length === 0) {
            listEl.innerHTML = `<div style="color:#9CA3AF; padding:20px; font-size:0.9rem;">No recent escrow activity.</div>`;
        } else {
            history.forEach((h, index) => {
                const item = document.createElement('div');
                item.className = 'activity-item';
                // Using a generic scan/focus icon as in screenshot
                item.innerHTML = `
                    <div style="display: flex; align-items: center; gap: 16px; width: 100%;">
                        <div class="activity-icon"><i class="fas fa-expand"></i></div>
                        <div class="activity-info">
                            <strong>Escrow #${h.id}</strong>
                            <span>${h.date} - ${h.amount} TND</span>
                        </div>
                    </div>
                `;
                listEl.appendChild(item);
            });
        }

        // Swap views instantly
        document.getElementById('escrowMainView').style.display = 'none';
        document.getElementById('contactDetailsView').style.display = 'block';
    }

    function closeContactDetails() {
        document.getElementById('contactDetailsView').style.display = 'none';
        document.getElementById('escrowMainView').style.display = 'block';
        currentContactId = null;
        currentContactName = '';
        currentContactPhone = '';
    }

    function editContactAlias(event) {
        event.stopPropagation();

        if (!currentContactId) return;

        Swal.fire({
            title: 'Update Alias',
            input: 'text',
            inputValue: currentContactName,
            showCancelButton: true,
            confirmButtonText: 'Update',
            background: '#151120',
            color: '#fff',
            inputValidator: (value) => {
                if (!value || !value.trim()) {
                    return 'Alias cannot be empty.';
                }

                if (value.trim().length > 255) {
                    return 'Alias must be 255 characters or less.';
                }
            }
        }).then((result) => {
            if (!result.isConfirmed) {
                return;
            }

            fetch(`/user/escrow/contact/${currentContactId}/alias`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ alias: result.value.trim() })
            })
            .then(res => res.json())
            .then(data => {
                if (!data.success) {
                    Swal.fire('Error', data.message || 'Failed to update alias.', 'error');
                    return;
                }

                currentContactName = data.alias;
                document.getElementById('cdName').innerHTML = `${data.alias} <i class="fas fa-pen" onclick="editContactAlias(event)"></i>`;
                Swal.fire({
                    title: 'Updated',
                    text: 'Alias updated successfully.',
                    icon: 'success',
                    background: '#151120',
                    color: '#fff'
                }).then(() => {
                    window.location.reload();
                });
            })
            .catch(() => {
                Swal.fire('Error', 'Network error.', 'error');
            });
        });
    }

    function editContactPhone(event) {
        event.stopPropagation();

        if (!currentContactId) return;

        Swal.fire({
            title: 'Update Phone Number',
            input: 'text',
            inputValue: currentContactPhone,
            inputPlaceholder: '+216 12 345 678',
            showCancelButton: true,
            confirmButtonText: 'Update',
            background: '#151120',
            color: '#fff',
            footer: '<span style="color:#9CA3AF; font-size:0.8rem;">Leave empty to use the phone from the user profile.</span>',
            inputValidator: (value) => {
                const trimmed = value.trim();

                if (trimmed === '') {
                    return undefined;
                }

                if (trimmed.length > 20) {
                    return 'Phone number must be 20 characters or less.';
                }

                if (!/^\+?[0-9 ]{8,20}$/.test(trimmed)) {
                    return 'Phone number can only contain digits, spaces, and an optional leading +.';
                }
            }
        }).then((result) => {
            if (!result.isConfirmed) {
                return;
            }

            fetch(`/user/escrow/contact/${currentContactId}/phone`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ phone: result.value.trim() })
            })
            .then(res => res.json())
            .then(data => {
                if (!data.success) {
                    Swal.fire('Error', data.message || 'Failed to update phone number.', 'error');
                    return;
                }

                currentContactPhone = data.phone !== 'N/A' ? data.phone : '';
                document.getElementById('cdPhone').innerText = data.phone;
                Swal.fire({
                    title: 'Updated',
                    text: 'Phone number updated successfully.',
                    icon: 'success',
                    background: '#151120',
                    color: '#fff'
                }).then(() => {
                    window.location.reload();
                });
            })
            .catch(() => {
                Swal.fire('Error', 'Network error.', 'error');
            });
        });
    }

    function removeContact() {
        if (!currentContactId) return;
        Swal.fire({
            title: `Remove from Contacts?`,
            text: "This action cannot be undone.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#EF4444',
            confirmButtonText: 'Yes, remove it!',
            background: '#151120',
            color: '#fff'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch(`/user/escrow/contact/${currentContactId}/remove`, {
                    method: 'POST'
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        Swal.fire({
                            title: 'Removed!',
                            text: 'Contact has been removed.',
                            icon: 'success',
                            background: '#151120',
                            color: '#fff'
                        }).then(() => {
                            window.location.reload();
                        });
                    } else {
                        Swal.fire('Error', data.message || 'Failed to remove contact.', 'error');
                    }
                })
                .catch(err => {
                    Swal.fire('Error', 'Network error occurred.', 'error');
                });
            }
        });
    }

    function promptAddContact() {
        Swal.fire({
            title: 'Add Trusted Contact',
            text: 'Enter the email address of the user you want to add:',
            input: 'text', // Changed from email to disable client-side browser validation
            inputPlaceholder: 'user@example.com',
            showCancelButton: true,
            confirmButtonText: 'Add Contact',
            confirmButtonColor: '#10B981',
            background: '#151120',
            color: '#fff',
            showLoaderOnConfirm: true,
            preConfirm: (email) => {
                return fetch('/user/escrow/contact/add', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ email: email })
                })
                .then(response => response.json())
                .then(data => {
                    if (!data.success) {
                        if (data.errors && data.errors.email) {
                            Swal.showValidationMessage(data.errors.email);
                        } else {
                            Swal.showValidationMessage(data.message || 'Failed to add contact');
                        }
                        return false; // Prevents closing the modal
                    }
                    return data;
                })
                .catch(error => {
                    Swal.showValidationMessage('A network error occurred.');
                    return false;
                });
            },
            allowOutsideClick: () => !Swal.isLoading()
        }).then((result) => {
            if (result.isConfirmed && result.value) {
                Swal.fire({
                    title: 'Added!',
                    text: result.value.message || 'Contact added successfully.',
                    icon: 'success',
                    background: '#151120',
                    color: '#fff'
                }).then(() => {
                    window.location.reload();
                });
            }
        });
    }

    // Modal Logic
    let currentEscrowId = null;
    let pollingInterval = null;

    function startPolling(escrowId) {
        stopPolling();
        pollingInterval = setInterval(() => {
            fetch(`/user/escrow/${escrowId}/status`, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(res => res.json())
            .then(data => {
                if (data.status === 'RELEASED') {
                    stopPolling();
                    closeModals();
                    Swal.fire({
                        title: 'Funds Released!',
                        text: 'The receiver has successfully scanned the code. Funds released.',
                        icon: 'success',
                        background: '#151120',
                        color: '#fff'
                    }).then(() => window.location.reload());
                }
            })
            .catch(err => console.error("Polling error:", err));
        }, 2000);
    }

    function stopPolling() {
        if (pollingInterval) {
            clearInterval(pollingInterval);
            pollingInterval = null;
        }
    }

    function switchTab(event, tabId) {
        event.preventDefault();
        
        // Remove active class from all tabs
        document.querySelectorAll('.tab-link').forEach(link => link.classList.remove('active'));
        event.target.classList.add('active');

        // Hide all tab contents
        document.querySelectorAll('.tab-content').forEach(content => {
            content.style.display = 'none';
        });

        // Show selected tab content
        const selectedTab = document.getElementById(tabId);
        if (selectedTab) {
            selectedTab.style.display = 'block';
        }
    }

    function openEscrowDetail(escrow) {
        currentEscrowId = escrow.id;
        
        // Populate static details
        document.getElementById('edTitle').innerText = 'Escrow #' + escrow.id;
        document.getElementById('edAmount').innerText = escrow.amount + ' TND';
        document.getElementById('edCondition').innerText = escrow.condition;
        
        const badge = document.getElementById('edStatusBadge');
        badge.innerText = escrow.status;
        if (escrow.status === 'LOCKED') {
            badge.style.background = '#fff7ed';
            badge.style.color = '#c2410c';
        } else if (escrow.status === 'RELEASED') {
            badge.style.background = '#ecfdf5';
            badge.style.color = '#047857';
        } else {
            badge.style.background = '#fef2f2';
            badge.style.color = '#b91c1c';
        }

        // Handle Views based on User Role and Status
        const senderView = document.getElementById('edSenderView');
        const receiverView = document.getElementById('edReceiverView');
        const disputeBtn = document.getElementById('edDisputeBtn');
        const refundBtn = document.getElementById('edRefundBtn');
        const secretCode = document.getElementById('edSecretCode');
        const qrCodeContainer = document.getElementById('edQrCodeContainer');
        const qrCodeImg = document.getElementById('edQrCode');
        const instruction = document.getElementById('edInstruction');

        senderView.style.display = 'none';
        receiverView.style.display = 'none';
        disputeBtn.style.display = escrow.status === 'LOCKED' ? 'block' : 'none';
        refundBtn.style.display = 'none';

        if (escrow.status === 'LOCKED') {
            if (escrow.isSender) {
                // SENDER UI
                senderView.style.display = 'block';
                
                if (escrow.type === 'QR_CODE') {
                    if (escrow.requireDocusign && !escrow.docusignEnvelopeId) { // Logic proxy for pending DocuSign
                        qrCodeContainer.style.display = 'none';
                        instruction.style.display = 'none';
                        secretCode.innerHTML = '<span style="color:#F59E0B; font-weight:bold;">✍️ Waiting for DocuSign Signatures</span>';
                    } else {
                        qrCodeContainer.style.display = 'inline-block';
                        instruction.style.display = 'block';
                        secretCode.innerHTML = 'Secret Code: <span style="font-family:monospace;">' + escrow.secretCode + '</span>';
                        
                        // Generate the exact same QR code as the Java App: https://escrow.finhub.tn/escrow/claim_ui?id={id}&secret={secretCode}
                        const qrData = "https://escrow.finhub.tn/escrow/claim_ui?id=" + escrow.id + "&secret=" + escrow.secretCode;
                        qrCodeImg.src = "https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=" + encodeURIComponent(qrData);
                        
                        startPolling(escrow.id);
                        
                        if (escrow.isExpired) {
                            refundBtn.style.display = 'block';
                        }
                    }
                } else {
                    // ADMIN APPROVAL
                    qrCodeContainer.style.display = 'none';
                    instruction.style.display = 'none';
                    secretCode.innerHTML = '<span style="color:#A78BFA; font-weight:bold;">⏳ Waiting for Admin Approval</span>';
                }
            } else {
                // RECEIVER UI
                receiverView.style.display = 'block';
            }
        }

        document.getElementById('escrowDetailsModal').classList.add('active');
    }

    function handleSenderRelease() {
        if (!currentEscrowId) return;
        
        Swal.fire({
            title: 'Release Funds?',
            text: "Are you sure you want to release these funds to the receiver? This action is irreversible.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#10B981',
            confirmButtonText: 'Yes, release funds!',
            background: '#151120',
            color: '#fff'
        }).then((result) => {
            if (result.isConfirmed) {
                postEscrowAction(`/user/escrow/${currentEscrowId}/release`);
            }
        });
    }

    function handleReceiverClaim() {
        if (!currentEscrowId) return;
        
        const code = document.getElementById('edCodeInput').value.trim();
        if (!code) {
            Swal.fire('Error', 'Please enter the secret code.', 'error');
            return;
        }
        
        postEscrowAction(`/user/escrow/${currentEscrowId}/claim`, { code: code });
    }

    function handleSenderRefund() {
        if (!currentEscrowId) return;
        postEscrowAction(`/user/escrow/${currentEscrowId}/refund`);
    }

    function handleDispute() {
        if (!currentEscrowId) return;

        Swal.fire({
            title: 'Dispute Transaction?',
            text: "This will lock the transaction until an admin reviews it. Are you sure?",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#EF4444',
            confirmButtonText: 'Yes, dispute it!',
            background: '#151120',
            color: '#fff'
        }).then((result) => {
            if (result.isConfirmed) {
                postEscrowAction(`/user/escrow/${currentEscrowId}/dispute`);
            }
        });
    }

    function deleteEscrowItem(escrowId, escrowStatus) {
        const statusLabel = (escrowStatus || 'escrow').toLowerCase();

        Swal.fire({
            title: `Delete ${statusLabel} escrow?`,
            text: 'This will permanently remove it from your history.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#EF4444',
            confirmButtonText: 'Delete',
            background: '#151120',
            color: '#fff'
        }).then((result) => {
            if (!result.isConfirmed) return;

            fetch(`/user/escrow/${escrowId}/delete`, {
                method: 'DELETE',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        title: 'Deleted!',
                        text: data.message,
                        icon: 'success',
                        background: '#151120',
                        color: '#fff'
                    }).then(() => window.location.reload());
                } else {
                    Swal.fire('Error', data.message || 'Failed to delete escrow.', 'error');
                }
            })
            .catch(() => {
                Swal.fire('Error', 'Network error occurred.', 'error');
            });
        });
    }

    function postEscrowAction(url, bodyData = {}) {
        fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify(bodyData)
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                Swal.fire({
                    title: 'Success!',
                    text: data.message,
                    icon: 'success',
                    background: '#151120',
                    color: '#fff'
                }).then(() => window.location.reload());
            } else {
                Swal.fire('Error', data.message || 'Action failed.', 'error');
            }
        })
        .catch(err => {
            Swal.fire('Error', 'Network error occurred.', 'error');
        });
    }
    function openNewEscrowModal() {
        document.getElementById('escrow_email').value = '';
        document.getElementById('escrow_amount').value = '';
        document.getElementById('escrow_conditions').value = '';
        document.getElementById('escrowDocuSign').checked = false;
        calculateEscrowFee(); // reset to 0
        document.getElementById('newEscrowModal').classList.add('active');
        
        // Remove old errors
        document.querySelectorAll('.text-danger.form-error').forEach(el => el.remove());
    }

    function openNewEscrowModalFromContact() {
        const email = document.getElementById('cdEmail').innerText;
        openNewEscrowModal();
        document.getElementById('escrow_email').value = email;
    }

    function closeModals() {
        stopPolling();
        document.querySelectorAll('.modal-overlay').forEach(modal => {
            modal.classList.remove('active');
        });
    }

    // Live Escrow Fee Calculation
    function calculateEscrowFee() {
        const amountInput = document.getElementById('escrow_amount').value;
        const amount = parseFloat(amountInput) || 0;
        
        const fee = amount * 0.01; // 1% Fee
        const total = amount; // The sender/buyer pays the full amount; fee is taken from the seller

        document.getElementById('feeSubtotal').innerText = amount.toFixed(3) + ' TND';
        document.getElementById('feeAmount').innerText = fee.toFixed(3) + ' TND (Paid by Seller)';
        document.getElementById('feeTotal').innerText = total.toFixed(3) + ' TND';
    }

    function submitNewEscrow(e) {
        e.preventDefault();
        
        // Clear previous errors
        document.querySelectorAll('.text-danger.form-error').forEach(el => el.remove());
        
        const btn = e.target.querySelector('.btn-submit');
        const email = document.getElementById('escrow_email').value;
        const amount = document.getElementById('escrow_amount').value;
        const type = document.getElementById('escrowMethod').value;
        const requireDocusign = document.getElementById('escrowDocuSign').checked;
        const conditions = document.getElementById('escrow_conditions').value;

        btn.disabled = true;
        btn.innerText = 'Creating...';

        fetch('/user/escrow/create', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: JSON.stringify({
                email: email,
                amount: amount,
                type: type,
                requireDocusign: requireDocusign,
                conditions: conditions
            })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                closeModals();
                Swal.fire({
                    title: 'Escrow Created!',
                    text: data.message || 'Your funds have been securely locked in escrow.',
                    icon: 'success',
                    background: '#151120',
                    color: '#fff'
                }).then(() => {
                    window.location.reload();
                });
            } else {
                if (data.errors) {
                    for (const [field, message] of Object.entries(data.errors)) {
                        const input = document.getElementById('escrow_' + field);
                        if (input) {
                            const errorSpan = document.createElement('span');
                            errorSpan.className = 'text-danger form-error';
                            errorSpan.style.color = '#EF4444';
                            errorSpan.style.fontSize = '0.85rem';
                            errorSpan.style.marginTop = '4px';
                            errorSpan.style.display = 'block';
                            errorSpan.innerText = message;
                            input.parentNode.appendChild(errorSpan);
                        } else {
                            // General error that does not map directly
                            Swal.fire('Error', message, 'error');
                        }
                    }
                } else {
                    Swal.fire('Error', data.message || 'Failed to create escrow.', 'error');
                }
                btn.disabled = false;
                btn.innerText = 'Create Escrow';
            }
        })
        .catch(err => {
            console.error(err);
            Swal.fire('Error', 'A network error occurred.', 'error');
            btn.disabled = false;
            btn.innerText = 'Create Escrow';
        });
    }
</script>
{% endblock %}
