            <div class="contact-sidebar">
                <div class="sidebar-avatar-large" id="cdAvatarWrapper">
                    <span class="initial" id="cdInitial"></span>
                    <img id="cdAvatar" style="display:none;" src="" alt="Avatar">
                </div>
                
                <h2 class="sidebar-name" id="cdName">
                    <!-- name inserted here via JS --> <i class="fas fa-pen"></i>
                </h2>

                <div class="sidebar-info-box">
