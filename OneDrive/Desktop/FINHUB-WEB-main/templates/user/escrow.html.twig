                    <label class="form-label" for="{{ escrowForm.amount.vars.id }}">{{ form_label(escrowForm.amount) }}</label>
                    {{ form_widget(escrowForm.amount, {'attr': {'class': 'form-input', 'placeholder': '0.000', 'oninput': 'calculateEscrowFee()'}}) }}
