<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="tn.finhub.controller.LoginController"
           style="-fx-background-color: transparent;">

    <VBox alignment="CENTER" spacing="20" maxWidth="400" maxHeight="500" styleClass="card" style="-fx-background-color: rgba(30, 27, 46, 0.85); -fx-border-color: #2E2A45; -fx-border-width: 1; -fx-border-radius: 16;">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <Label text="%login.title" styleClass="header-text"/>
        <Label text="%login.subtitle" styleClass="sub-header-text"/>
        
        <Region prefHeight="20"/>

        <VBox spacing="5" alignment="CENTER_LEFT" maxWidth="Infinity">
            <Label text="%login.email" style="-fx-text-fill: -color-text-secondary; -fx-font-size: 12px;"/>
            <TextField fx:id="emailField" promptText="%login.email.prompt" styleClass="text-field"/>
        </VBox>

        <VBox spacing="5" alignment="CENTER_LEFT" maxWidth="Infinity">
            <Label text="%login.password" style="-fx-text-fill: -color-text-secondary; -fx-font-size: 12px;"/>
            <PasswordField fx:id="passwordField" promptText="%login.password.prompt" styleClass="text-field"/>
        </VBox>
        
        <Region prefHeight="10"/>

        <Button text="%login.button" onAction="#handleLogin" maxWidth="Infinity" styleClass="button-primary"/>
        
        <Label text="OR" style="-fx-text-fill: -color-text-secondary; -fx-font-size: 12px;"/>
        
        <Button text="Continue with Google" onAction="#handleGoogleLogin" maxWidth="Infinity" style="-fx-background-color: white; -fx-text-fill: #3c4043; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 10px; -fx-background-radius: 8px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 5, 0, 0, 2);">
            <graphic>
                <javafx.scene.shape.SVGPath content="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#4285F4" scaleX="0.8" scaleY="0.8"/>
            </graphic>
        </Button>

        <HBox alignment="CENTER" spacing="5">
            <Label text="%login.no.account" style="-fx-text-fill: -color-text-secondary;"/>
            <Hyperlink text="%login.create.account" onAction="#goToSignup" styleClass="hyperlink"/>
        </HBox>
        
        <Hyperlink text="%login.forgot.password" onAction="#goToForgotPassword" styleClass="hyperlink" style="-fx-font-size: 12px;"/>

        <Label fx:id="messageLabel" textFill="#ef4444"/>

    </VBox>

</StackPane>

